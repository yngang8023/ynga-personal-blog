---
import { Icon } from "astro-icon/components";

import { licenseConfig, profileConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

interface Props {
	title: string;
	id: string;
	pubDate: Date;
	class: string;
	author: string;
	sourceLink: string;
	licenseName: string;
	licenseUrl: string;
}

const { title, pubDate, author, sourceLink, licenseName, licenseUrl } =
	Astro.props;
const className = Astro.props.class;
const profileConf = profileConfig;
const licenseConf = licenseConfig;
const postUrl = sourceLink || decodeURIComponent(Astro.url.toString());
---

<div
	class={`relative transition overflow-hidden bg-[var(--license-block-bg)] py-5 px-6 ${className}`}
>
	<div class="transition font-bold text-black/75 dark:text-white/75">
		{title}
	</div>
	<a href={postUrl} class="link text-[var(--primary)]">
		{postUrl}
	</a>
	<div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-3 sm:gap-6">
		<div class="min-w-0 flex flex-wrap items-baseline gap-x-2 gap-y-1 sm:block">
			<div class="transition text-black/30 dark:text-white/30 text-sm shrink-0">
				{i18n(I18nKey.author)}
			</div>
			<div
				class="transition text-black/75 dark:text-white/75 line-clamp-2 sm:mt-0.5"
			>
				{author || profileConf.name}
			</div>
		</div>
		<div class="min-w-0 flex flex-wrap items-baseline gap-x-2 gap-y-1 sm:block">
			<div class="transition text-black/30 dark:text-white/30 text-sm shrink-0">
				{i18n(I18nKey.publishedAt)}
			</div>
			<div
				class="transition text-black/75 dark:text-white/75 line-clamp-2 sm:mt-0.5"
			>
				{formatDateToYYYYMMDD(pubDate)}
			</div>
		</div>
		<div class="min-w-0 flex flex-wrap items-baseline gap-x-2 gap-y-1 sm:block">
			<div class="transition text-black/30 dark:text-white/30 text-sm shrink-0">
				{i18n(I18nKey.license)}
			</div>
			<a
				href={licenseName ? licenseUrl || undefined : licenseConf.url}
				target="_blank"
				class="link text-[var(--primary)] line-clamp-2 sm:mt-0.5"
				>{licenseName || licenseConf.name}</a
			>
		</div>
	</div>
	<Icon
		name="fa7-brands:creative-commons"
		class="transition text-[15rem] absolute pointer-events-none right-6 top-1/2 -translate-y-1/2 text-black/5 dark:text-white/5"
	/>
</div>
