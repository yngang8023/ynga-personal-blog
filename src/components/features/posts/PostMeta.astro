---
import { Icon } from "astro-icon/components";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import { formatDateToYYYYMMDD } from "../../../utils/date-utils";
import { getTagUrl } from "../../../utils/url-utils";
import { PublishedDate } from "./atoms";
import { Category } from "./atoms";
import { WordCount } from "./atoms";
import { ReadingTime } from "./atoms";
import { EncryptedBadge } from "./atoms";

interface Props {
	published: Date;
	updated?: Date;
	category?: string;
	tags?: string[];
	hideUpdateDate?: boolean;
	hideTagsForMobile?: boolean;
	isHome?: boolean;
	className?: string;
	id?: string;
	showOnlyBasicMeta?: boolean;
	words?: number;
	minutes?: number;
	showWordCount?: boolean;
	showReadingTime?: boolean;
	showEncrypted?: boolean;
	showPageViews?: boolean;
	path?: string;
}

const {
	published,
	updated,
	category,
	tags,
	hideUpdateDate,
	hideTagsForMobile,
	isHome,
	className = "",
	id,
	showOnlyBasicMeta = false,
	words,
	minutes,
	showWordCount = false,
	showReadingTime = false,
	showEncrypted = false,
	showPageViews = true,
	path,
} = Astro.props;
---

<div class:list={["flex flex-wrap text-neutral-500 dark:text-neutral-400 items-center gap-4 gap-x-4 gap-y-2", className]}>
    <PublishedDate date={published} />

    {!hideUpdateDate && updated && updated.getTime() !== published.getTime() && (
        <div class="flex items-center">
            <div class="meta-icon">
                <Icon name="material-symbols:edit-calendar-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium">{formatDateToYYYYMMDD(updated)}</span>
        </div>
    )}

    <Category category={category} />

    {showWordCount && words && (
        <WordCount words={words} />
    )}

    {showReadingTime && minutes && (
        <ReadingTime minutes={minutes} />
    )}

    {!showOnlyBasicMeta && (
        <div class:list={["items-center", {"flex": !hideTagsForMobile, "hidden md:flex": hideTagsForMobile}]}>
            <div class="meta-icon">
                <Icon name="material-symbols:tag-rounded" class="text-xl"></Icon>
            </div>
            <div class="flex flex-row flex-nowrap items-center">
                {(tags && tags.length > 0) && tags.map((tag, i) => (
                    <>
                        <div class:list={[{"hidden": i == 0}, "mx-1.5 text-[var(--meta-divider)] text-sm"]}>/</div>
                        <a href={getTagUrl(tag)} aria-label={`View all posts with the ${tag.trim()} tag`}
                           class="link-lg transition text-50 text-sm font-medium
                                        hover:text-[var(--primary)] dark:hover:text-[var(--primary)] whitespace-nowrap">
                            {tag.trim()}
                        </a>
                    </>
                ))}
                {!(tags && tags.length > 0) && <div class="transition text-50 text-sm font-medium">{i18n(I18nKey.noTags)}</div>}
            </div>
        </div>
    )}
    
    {!isHome && id && showPageViews && (
        <div class="flex items-center umami-page-views hidden" data-id={id} data-path={path}>
            <div class="meta-icon">
                <Icon name="material-symbols:visibility-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium page-views-display">{i18n(I18nKey.pageViewsLabel)} --</span>
        </div>
    )}

    {showEncrypted && (
        <EncryptedBadge />
    )}
    
    {!isHome && id && showPageViews && (
<script is:inline define:vars={{
    pageViewsText: i18n(I18nKey.pageViewsLabel)
}}>
    function ensurePageViewsManager() {
        if (window.__mizukiPageViewsManager) {
            return window.__mizukiPageViewsManager;
        }

        const manager = {
            fetching: false,
            refresh: async (attempt = 0) => {
                const maxRetries = 8;
                const retryDelay = 700;
                const containers = Array.from(document.querySelectorAll('.umami-page-views'));

                if (containers.length === 0 || manager.fetching) {
                    return;
                }

                if (!window.oddmisc?.getStats) {
                    if (attempt < maxRetries) {
                        window.setTimeout(() => manager.refresh(attempt + 1), retryDelay);
                    }
                    return;
                }

                manager.fetching = true;

                try {
                    await Promise.all(containers.map(async (container) => {
                        const statsPath = container?.dataset.path;
                        if (!statsPath) {
                            return;
                        }

                        const stats = await window.oddmisc.getStats(statsPath);
                        const pageViews = stats.pageviews ?? 0;

                        container.classList.remove('hidden');
                        const display = container.querySelector('.page-views-display');
                        if (display) {
                            display.textContent = `${pageViewsText} ${pageViews}`;
                        }
                    }));
                } catch (error) {
                    if (attempt < maxRetries) {
                        manager.fetching = false;
                        window.setTimeout(() => manager.refresh(attempt + 1), retryDelay);
                        return;
                    }

                    console.error('Error fetching page views:', error);
                    containers.forEach((container) => {
                        const display = container.querySelector('.page-views-display');
                        container.classList.remove('hidden');
                        if (display) {
                            display.textContent = `${pageViewsText} --`;
                        }
                    });
                } finally {
                    manager.fetching = false;
                }
            }
        };

        window.__mizukiPageViewsManager = manager;
        return manager;
    }

    const pageViewsManager = ensurePageViewsManager();

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => pageViewsManager.refresh());
    } else {
        pageViewsManager.refresh();
    }

    window.addEventListener('mizuki:umami-ready', () => {
        pageViewsManager.refresh();
    });

    document.addEventListener('astro:page-load', () => {
        pageViewsManager.refresh();
    });
</script>
)}
