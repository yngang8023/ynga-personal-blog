---
import ProtectedRagEmbed from "@components/rag/ProtectedRagEmbed.astro";
import { PageHeader } from "@components/features/page-header";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import {
	ASK_Y_PAGE_SUBTITLE,
	ASK_Y_PAGE_TITLE,
} from "../constants/ask-y-page";

export const prerender = true;
---

<MainGridLayout
	title={ASK_Y_PAGE_TITLE}
	description={ASK_Y_PAGE_SUBTITLE}
	hideSidebars={true}
>
	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-4 py-6 sm:px-6 lg:px-9 relative w-full">
			<PageHeader
				title={ASK_Y_PAGE_TITLE}
				subtitle={ASK_Y_PAGE_SUBTITLE}
			/>

			<section class="ask-y-shell">
				<div class="ask-y-embed-card">
					<ProtectedRagEmbed title="问问小Y对话页" />
				</div>
			</section>
		</div>
	</div>
</MainGridLayout>

<style>
	.ask-y-shell {
		display: grid;
		gap: 0.85rem;
	}

	.ask-y-embed-card {
		padding: 0;
	}

	.ask-y-embed-card :global(.protected-rag-embed) {
		min-height: clamp(48rem, calc(100dvh - 12.75rem), 74rem);
		max-height: none;
	}

	@media (max-width: 640px) {
		.ask-y-shell {
			gap: 0.75rem;
		}
	}
</style>
