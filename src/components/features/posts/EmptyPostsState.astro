---
import { Icon } from "astro-icon/components";

interface Props {
	title?: string;
	description?: string;
	compact?: boolean;
}

const {
	title = "还没有文章",
	description = "先写下第一篇文章吧，新的内容会在这里出现。",
	compact = false,
} = Astro.props;
---

<section
	class:list={[
		"overflow-hidden rounded-[var(--radius-large)] border border-white/60 bg-[var(--card-bg)] shadow-[0_20px_60px_rgba(0,0,0,0.05)]",
		compact ? "px-6 py-10" : "px-8 py-14 md:px-12 md:py-18",
	]}
>
	<div class="mx-auto flex max-w-2xl flex-col items-center text-center">
		<div
			class="mb-5 flex h-20 w-20 items-center justify-center rounded-[1.75rem] bg-[linear-gradient(135deg,oklch(0.97_0.03_var(--hue)),oklch(0.93_0.06_var(--hue)))] text-[var(--primary)] shadow-[0_18px_40px_rgba(217,153,0,0.18)] md:h-24 md:w-24"
		>
			<Icon
				name="material-symbols:article-outline-rounded"
				class="text-[2.5rem] md:text-[3rem]"
			/>
		</div>
		<h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100 md:text-2xl">
			{title}
		</h2>
		<p class="mt-3 max-w-xl text-sm leading-7 text-neutral-500 dark:text-neutral-400 md:text-base">
			{description}
		</p>
		<div class="mt-6 flex items-center gap-2 rounded-full bg-[oklch(0.97_0.02_var(--hue))] px-4 py-2 text-sm text-[var(--primary)] dark:bg-white/5">
			<Icon name="material-symbols:edit-square-outline-rounded" class="text-lg" />
			<span>支持 Markdown，写好后会自动显示在这里</span>
		</div>
	</div>
</section>
