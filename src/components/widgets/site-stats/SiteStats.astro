---
import { Icon } from "astro-icon/components";

import { siteConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "../../../utils/content-utils";
import { resolvePostLastModifiedDate } from "../../../utils/post-last-modified";
import { getPostUrl } from "../../../utils/url-utils";
import WidgetLayout from "../common/WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

// 从配置中获取站点开始日期
const siteStartDate = siteConfig.siteStartDate || "2025-01-01";
const relativeTimeLocale = (siteConfig.lang || "en").replaceAll("_", "-");

// 获取所有文章
const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();
const postPaths = posts.map((post) => getPostUrl(post));

// 计算总字数
let totalWords = 0;
for (const post of posts) {
	if (post.body) {
		let text = post.body;

		// 移除代码块
		text = text.replace(/```[\s\S]*?```/g, "");
		// 移除 ` 包裹的行内代码
		text = text.replace(/`[^`]+`/g, "");

		// 使用与 remark-content.mjs 完全一致的 CJK 正则
		const cjkPattern =
			/[\u4e00-\u9fa5\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af\u3000-\u303f\uff00-\uffef]/g;

		const cjkMatches = text.match(cjkPattern);
		const cjkCount = cjkMatches ? cjkMatches.length : 0;

		// 计算非 CJK 单词数
		const nonCjkText = text.replace(cjkPattern, " ");

		// 按空白字符分割，计算单词数量
		const nonCjkWords = nonCjkText
			.split(/\s+/)
			.filter((word) => word.trim().length > 0);

		totalWords += cjkCount + nonCjkWords.length;
	}
}

// 格式化数字（添加千位分隔符）
function formatNumber(num: number): string {
	return num.toLocaleString();
}

// 获取最新发布的文章，并基于该文章的真实活动时间生成统计数据
const latestPost = posts.reduce<typeof posts[number] | null>((latest, post) => {
	if (!latest) {
		return post;
	}
	return post.data.published > latest.data.published ? post : latest;
}, null);

const lastActivityDate = latestPost
	? await resolvePostLastModifiedDate(latestPost)
	: null;
const lastActivityTimestamp = lastActivityDate?.getTime() ?? null;

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length,
	},
	{
		icon: "material-symbols:folder-outline",
		label: i18n(I18nKey.siteStatsCategoryCount),
		value: categories.length,
	},
	{
		icon: "material-symbols:label-outline",
		label: i18n(I18nKey.siteStatsTagCount),
		value: tags.length,
	},
	{
		icon: "material-symbols:text-ad-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalWords),
		value: totalWords,
		formatted: true,
	},
	{
		icon: "material-symbols:local-library-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalViews),
		value: "--",
		dynamic: true,
		id: "total-views",
	},
	{
		icon: "material-symbols:calendar-clock-outline",
		label: i18n(I18nKey.siteStatsRunningDays),
		value: 0, // 将由客户端更新
		suffix: i18n(I18nKey.siteStatsDays).replace("{days}", ""),
		dynamic: true,
		id: "running-days",
	},
	{
		icon: "material-symbols:ecg-heart-outline",
		label: i18n(I18nKey.siteStatsLastUpdate),
		value: "-", // 将由客户端更新
		dynamic: true,
		id: "last-update",
	},
];
---

<WidgetLayout
	name={i18n(I18nKey.siteStats)}
	id="site-stats"
	class={className}
	style={style}
>
	<div class="flex flex-col gap-1">
		{
			stats.map((stat) => (
				<div class="flex items-center justify-between px-2 py-2">
					<div class="flex items-center gap-2.5 flex-1 min-w-0">
						<div class="text-[var(--primary)] text-xl shrink-0">
							<Icon name={stat.icon} />
						</div>
						<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
							{stat.label}
						</span>
					</div>
					<div class="flex items-center ml-3 shrink-0">
						<span
							class="text-base font-bold text-neutral-900 dark:text-neutral-100"
							data-stat-id={stat.id}
						>
							{stat.formatted
								? formatNumber(stat.value)
								: stat.value}
						</span>
						{stat.suffix && (
							<span class="text-sm text-neutral-500 dark:text-neutral-400 ml-1">
								{stat.suffix}
							</span>
						)}
					</div>
				</div>
			))
		}
	</div>
</WidgetLayout>

<script
	is:inline
	define:vars={{
		siteStartDate,
		lastActivityTimestamp,
		relativeTimeLocale,
		postPaths,
	}}
>
	function updateDynamicStats() {
		const today = new Date();

		// 更新运行天数
		const startDate = new Date(siteStartDate);
		const diffTime = Math.abs(today.getTime() - startDate.getTime());
		const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

		const runningDaysElements = document.querySelectorAll(
			'[data-stat-id="running-days"]',
		);
		if (runningDaysElements.length > 0) {
			runningDaysElements.forEach((element) => {
				element.textContent = diffDays.toString();
			});
		}

		// 更新最后活动时间
		if (lastActivityTimestamp) {
			const lastPostTime = Number(lastActivityTimestamp);
			if (Number.isNaN(lastPostTime)) {
				return;
			}

			const minuteMs = 1000 * 60;
			const hourMs = minuteMs * 60;
			const dayMs = hourMs * 24;
			const timeSinceLastPost = Math.max(
				0,
				today.getTime() - lastPostTime,
			);

			const formatter = new Intl.RelativeTimeFormat(
				relativeTimeLocale,
				{
					numeric: "always",
				},
			);

			let lastActivityText = "";
			if (timeSinceLastPost < hourMs) {
				const minutesSinceLastUpdate = Math.max(
					1,
					Math.floor(timeSinceLastPost / minuteMs),
				);
				lastActivityText = formatter.format(
					-minutesSinceLastUpdate,
					"minute",
				);
			} else if (timeSinceLastPost < dayMs) {
				const hoursSinceLastUpdate = Math.max(
					1,
					Math.floor(timeSinceLastPost / hourMs),
				);
				lastActivityText = formatter.format(
					-hoursSinceLastUpdate,
					"hour",
				);
			} else {
				const daysSinceLastUpdate = Math.max(
					1,
					Math.floor(timeSinceLastPost / dayMs),
				);
				lastActivityText = formatter.format(
					-daysSinceLastUpdate,
					"day",
				);
			}

			const lastUpdateElements = document.querySelectorAll(
				'[data-stat-id="last-update"]',
			);
			if (lastUpdateElements.length > 0) {
				lastUpdateElements.forEach((element) => {
					element.textContent = lastActivityText;
				});
			}
		}
	}

	async function updateUmamiStats(attempt = 0) {
		const maxRetries = 8;
		const retryDelay = 700;

		const totalViewsElements = document.querySelectorAll(
			'[data-stat-id="total-views"]',
		);
		if (totalViewsElements.length === 0) {
			return;
		}

		if (!window.oddmisc?.getSiteStats) {
			if (attempt < maxRetries) {
				window.setTimeout(
					() => updateUmamiStats(attempt + 1),
					retryDelay,
				);
			}
			return;
		}

		try {
			const pageviewsList = await Promise.all(
				postPaths.map(async (path) => {
					const stats = await window.oddmisc.getStats(path);
					return stats.pageviews ?? 0;
				}),
			);
			const totalViews = pageviewsList.reduce(
				(sum, views) => sum + views,
				0,
			);

			totalViewsElements.forEach((element) => {
				element.textContent = totalViews.toLocaleString();
			});
		} catch (error) {
			if (attempt < maxRetries) {
				window.setTimeout(
					() => updateUmamiStats(attempt + 1),
					retryDelay,
				);
				return;
			}

			console.error("Error fetching total views:", error);
		}
	}

	// 页面加载时更新
	updateDynamicStats();
	updateUmamiStats();

	// 最后活动需要按分钟刷新，运行天数顺带一起更新即可
	setInterval(updateDynamicStats, 60 * 1000);

	window.addEventListener("mizuki:umami-ready", () => {
		updateUmamiStats();
	});

	document.addEventListener("astro:page-load", () => {
		updateDynamicStats();
		updateUmamiStats();
	});
</script>
