---
import { Icon } from "astro-icon/components";

import FloatingButton from "@components/common/FloatingButton.astro";
import { blogRagConfig } from "../../config";

const embedUrl = blogRagConfig.embedUrl;
const tokenEndpoint = blogRagConfig.tokenEndpoint;
---

<div class="ai-chat-widget">
	<FloatingButton
		id="ai-chat-btn"
		icon="material-symbols:smart-toy-outline-rounded"
		ariaLabel="AI Assistant"
		onclick="window.toggleAiChat?.()"
	/>

	<div id="ai-chat-backdrop" class="ai-chat-backdrop" hidden></div>
	<section
		id="ai-chat-panel"
		class="ai-chat-panel"
		aria-hidden="true"
		aria-label="AI Assistant"
	>
		<header class="ai-chat-panel__header">
			<div class="ai-chat-panel__title">
				<Icon name="material-symbols:smart-toy-outline-rounded" />
				<span>AI 助手</span>
			</div>
			<button
				id="ai-chat-close"
				type="button"
				class="ai-chat-panel__close"
				aria-label="Close AI Assistant"
			>
				<Icon name="material-symbols:close-rounded" />
			</button>
		</header>
		<div class="ai-chat-panel__body">
			<div
				id="ai-chat-status"
				class="ai-chat-status"
				role="status"
				aria-live="polite"
				hidden
			></div>
			<iframe
				id="ai-chat-iframe"
				title="Ynga Blog AI Assistant"
				data-src={embedUrl}
				data-token-endpoint={tokenEndpoint}
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
				allow="clipboard-write"
			></iframe>
		</div>
	</section>
</div>

<style>
	.ai-chat-widget {
		position: relative;
		z-index: 120;
		pointer-events: auto;
	}

	.ai-chat-widget.is-open {
		z-index: 132;
	}

	.ai-chat-backdrop {
		position: fixed;
		inset: 0;
		z-index: 118;
		background: rgba(15, 23, 42, 0.14);
		backdrop-filter: blur(1.5px);
	}

	.ai-chat-panel {
		position: fixed;
		right: calc(var(--fab-group-right) + var(--fab-button-size) + 0.18rem);
		top: max(4.85rem, calc(var(--page-top, 0rem) + 0.7rem));
		bottom: 0.65rem;
		z-index: 129;
		display: flex;
		flex-direction: column;
		width: min(43rem, calc(100vw - 4.25rem));
		height: auto;
		min-height: clamp(38rem, calc(100dvh - 9rem), 50rem);
		max-height: calc(100dvh - max(4.85rem, calc(var(--page-top, 0rem) + 0.7rem)) - 0.65rem);
		overflow: hidden;
		background: var(--card-bg);
		border: 1px solid var(--line-color);
		border-radius: 1.35rem;
		box-shadow:
			0 28px 90px rgba(15, 23, 42, 0.22),
			0 12px 34px rgba(15, 23, 42, 0.14);
		opacity: 0;
		visibility: hidden;
		transform: translate3d(0, 0.85rem, 0) scale(0.985);
		transform-origin: bottom right;
		transition:
			opacity 0.2s ease,
			visibility 0.2s ease,
			transform 0.2s ease;
		pointer-events: none;
	}

	.ai-chat-widget.is-open .ai-chat-panel {
		opacity: 1;
		visibility: visible;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	:global(#ai-chat-btn.active) {
		background: var(--btn-card-bg-active);
		border-color: rgba(148, 163, 184, 0.45);
		box-shadow: var(--shadow-button);
		backdrop-filter: none;
		opacity: 1;
		filter: none;
		transform: none;
	}

	:global(#ai-chat-btn.active .floating-btn__inner) {
		background: transparent;
	}

	:global(#ai-chat-btn.active .floating-btn__icon) {
		opacity: 1;
		filter: none;
		transform: scale(1);
	}

	:global(.dark #ai-chat-btn.active) {
		border-color: rgba(255, 255, 255, 0.15);
		box-shadow: var(--shadow-button-dark);
	}

	.ai-chat-panel__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		min-height: 3rem;
		padding: 0.625rem 0.75rem 0.625rem 1rem;
		background: var(--card-bg);
		border-bottom: 1px solid var(--line-color);
		color: var(--primary);
	}

	.ai-chat-panel__title {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1;
	}

	.ai-chat-panel__title :global(svg) {
		width: 1.2rem;
		height: 1.2rem;
		flex: 0 0 auto;
	}

	.ai-chat-panel__close {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		flex: 0 0 auto;
		border: 0;
		border-radius: 0.625rem;
		background: transparent;
		color: var(--content-meta);
		cursor: pointer;
		transition:
			background 0.18s ease,
			color 0.18s ease,
			transform 0.18s ease;
	}

	.ai-chat-panel__close:hover {
		background: var(--btn-regular-bg);
		color: var(--primary);
	}

	.ai-chat-panel__close:active {
		transform: scale(0.94);
	}

	.ai-chat-panel__close :global(svg) {
		width: 1.25rem;
		height: 1.25rem;
	}

	.ai-chat-panel__body {
		position: relative;
		min-width: 0;
		min-height: 0;
		flex: 1 1 auto;
		background: var(--card-bg);
	}

	.ai-chat-status {
		position: absolute;
		inset: 0;
		z-index: 1;
		display: grid;
		place-items: center;
		padding: 1rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.78));
		color: var(--content-meta);
		font-size: 0.95rem;
		line-height: 1.6;
		text-align: center;
	}

	:global(.dark) .ai-chat-status {
		background:
			linear-gradient(180deg, rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.72));
	}

	.ai-chat-status[data-state="error"] {
		color: var(--primary);
	}

	.ai-chat-status[hidden] {
		display: none;
	}

	.ai-chat-panel iframe {
		display: block;
		width: 100%;
		min-width: 0;
		height: 100%;
		min-height: 0;
		flex: 1 1 auto;
		border: 0;
		background: var(--card-bg);
	}

	:global(html.ai-chat-open) .floating-controls-container {
		z-index: 124;
	}

	@media (max-width: 768px) {
		.ai-chat-panel {
			inset: 4.65rem 0.55rem 0.45rem;
			width: auto;
			min-height: 0;
			max-height: none;
			height: auto;
			border-radius: 1.125rem;
			transform-origin: bottom center;
		}
	}

	@media (max-width: 480px) {
		.ai-chat-panel {
			inset: 4.2rem 0.35rem 0.35rem;
			width: auto;
			min-height: 0;
			max-height: none;
			height: auto;
			border-radius: 1rem;
		}

		.ai-chat-panel__header {
			min-height: 2.75rem;
			padding: 0.5rem 0.625rem 0.5rem 0.875rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.ai-chat-panel,
		.ai-chat-panel__close {
			transition: none;
		}
	}
</style>

<script is:inline>
	(() => {
		const win = window;
		const doc = document;

		if (typeof win.__aiChatWidgetCleanup === "function") {
			win.__aiChatWidgetCleanup();
		}

		const widget = doc.querySelector(".ai-chat-widget");
		const button = doc.getElementById("ai-chat-btn");
		const panel = doc.getElementById("ai-chat-panel");
		const iframe = doc.getElementById("ai-chat-iframe");
		const status = doc.getElementById("ai-chat-status");
		const closeButton = doc.getElementById("ai-chat-close");
		const backdrop = doc.getElementById("ai-chat-backdrop");

		if (
			!widget ||
			!button ||
			!panel ||
			!iframe ||
			!status ||
			!closeButton ||
			!backdrop
		) {
			return;
		}

		let isOpen = false;
		let themeObserver = null;
		let iframeBootstrapPromise = null;
		let previousFocus = null;

		function getThemeMode() {
			return doc.documentElement.classList.contains("dark") ? "dark" : "light";
		}

		function setStatus(message, state = "loading") {
			status.textContent = message;
			status.dataset.state = state;
			status.hidden = false;
		}

		function clearStatus() {
			status.hidden = true;
			status.textContent = "";
			delete status.dataset.state;
		}

		function postThemeToIframe() {
			const theme = getThemeMode();
			if (iframe?.contentWindow) {
				iframe.contentWindow.postMessage(
					{
						type: "ynga-theme-change",
						theme,
					},
					"*",
				);
			}
		}

		async function loadIframe() {
			if (iframe.getAttribute("src") && iframe.dataset.ready === "true") {
				clearStatus();
				return true;
			}

			if (iframeBootstrapPromise) {
				return iframeBootstrapPromise;
			}

			const src = iframe.getAttribute("data-src");
			const tokenEndpointUrl = iframe.getAttribute("data-token-endpoint");
			if (!src || !tokenEndpointUrl) {
				setStatus("AI 助手加载配置缺失，请稍后重试。", "error");
				return false;
			}

			setStatus("正在连接 AI 助手...", "loading");
			iframe.dataset.ready = "false";
			iframeBootstrapPromise = (async () => {
				try {
					const response = await fetch(tokenEndpointUrl, {
						method: "GET",
						cache: "no-store",
						credentials: "same-origin",
						headers: {
							accept: "application/json",
						},
					});

					if (!response.ok) {
						throw new Error(`bootstrap token request failed: ${response.status}`);
					}

					const payload = await response.json();
					if (typeof payload?.token !== "string" || payload.token.length === 0) {
						throw new Error("bootstrap token response is missing token");
					}

					const url = new URL(src, window.location.href);
					url.searchParams.set("theme", getThemeMode());
					url.searchParams.set("embed_token", payload.token);
					iframe.dataset.ready = "false";
					iframe.setAttribute("src", url.toString());
					return true;
				} catch {
					iframe.dataset.ready = "false";
					iframe.removeAttribute("src");
					setStatus("AI 助手加载失败，请稍后再试。", "error");
					return false;
				} finally {
					iframeBootstrapPromise = null;
				}
			})();

			return iframeBootstrapPromise;
		}

		function setOpen(nextOpen) {
			isOpen = nextOpen;
			widget.classList.toggle("is-open", isOpen);
			button.classList.toggle("active", isOpen);
			backdrop.hidden = !isOpen;
			doc.documentElement.classList.toggle("ai-chat-open", isOpen);

			if (isOpen) {
				previousFocus = doc.activeElement instanceof HTMLElement ? doc.activeElement : null;
				panel.removeAttribute("inert");
				panel.setAttribute("aria-hidden", "false");
				queueMicrotask(() => {
					if (closeButton instanceof HTMLElement) {
						closeButton.focus({ preventScroll: true });
					}
				});
				loadIframe().then((loaded) => {
					if (loaded && isOpen) {
						postThemeToIframe();
					}
				});
				return;
			}

			if (doc.activeElement instanceof HTMLElement && panel.contains(doc.activeElement)) {
				button.focus({ preventScroll: true });
			} else if (previousFocus instanceof HTMLElement && doc.contains(previousFocus)) {
				previousFocus.focus({ preventScroll: true });
			}
			panel.setAttribute("aria-hidden", "true");
			panel.setAttribute("inert", "");
		}

		function toggleAiChat(forceOpen) {
			setOpen(typeof forceOpen === "boolean" ? forceOpen : !isOpen);
		}

		function handleKeydown(event) {
			if (event.key === "Escape" && isOpen) {
				setOpen(false);
			}
		}

		function handleClose() {
			setOpen(false);
		}

		function handleIframeLoad() {
			iframe.dataset.ready = "true";
			clearStatus();
		}

		function handleIframeError() {
			iframe.dataset.ready = "false";
			iframe.removeAttribute("src");
			setStatus("AI 助手加载失败，请稍后再试。", "error");
		}

		win.toggleAiChat = toggleAiChat;
		closeButton.addEventListener("click", handleClose);
		backdrop.addEventListener("click", handleClose);
		iframe.addEventListener("load", handleIframeLoad);
		iframe.addEventListener("error", handleIframeError);
		doc.addEventListener("keydown", handleKeydown);
		themeObserver = new MutationObserver(() => {
			if (isOpen) {
				postThemeToIframe();
			}
		});
		themeObserver.observe(doc.documentElement, {
			attributes: true,
			attributeFilter: ["class", "data-theme"],
		});

		win.__aiChatWidgetCleanup = () => {
			closeButton.removeEventListener("click", handleClose);
			backdrop.removeEventListener("click", handleClose);
			iframe.removeEventListener("load", handleIframeLoad);
			iframe.removeEventListener("error", handleIframeError);
			doc.removeEventListener("keydown", handleKeydown);
			themeObserver?.disconnect();
			themeObserver = null;
			if (win.toggleAiChat === toggleAiChat) {
				delete win.toggleAiChat;
			}
		};
	})();
</script>
