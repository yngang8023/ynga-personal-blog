---
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import { getCategoryList } from "../../../utils/content-utils";
import {
	getComponentConfig,
	widgetManager,
} from "../../../utils/widget-manager";
import ButtonLink from "../../control/ButtonLink.astro";
import WidgetEmptyState from "../common/WidgetEmptyState.astro";
import WidgetLayout from "../common/WidgetLayout.astro";

const categories = await getCategoryList();
const categoriesWidgetConfig = getComponentConfig("categories");
const isCollapsed = widgetManager.isCollapsed(
	categoriesWidgetConfig,
	categories.length,
);
const collapsedHeight = widgetManager.getCustomProp(
	categoriesWidgetConfig,
	"collapsedHeight",
	"7.5rem",
);
const collapsedRows = widgetManager.getCustomProp(
	categoriesWidgetConfig,
	"collapsedRows",
	3,
);

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout
	name={i18n(I18nKey.categories)}
	id="categories"
	isCollapsed={isCollapsed}
	collapsedHeight={collapsedHeight}
	collapsedRows={collapsedRows}
	class={className}
	style={style}
>
	{
		categories.length > 0 ? (
			categories.map((c) => (
				<ButtonLink
					url={c.url}
					badge={String(c.count)}
					label={`View all posts in the ${c.name.trim()} category`}
				>
					{c.name.trim()}
				</ButtonLink>
			))
		) : (
			<WidgetEmptyState
				icon="material-symbols:folder-outline"
				title={i18n(I18nKey.categoriesEmpty)}
				compact={true}
			/>
		)
	}
</WidgetLayout>
