---
import { Icon } from "astro-icon/components";

import ProtectedRagEmbed from "@components/rag/ProtectedRagEmbed.astro";
import Layout from "@layouts/Layout.astro";

import { ASK_Y_PAGE_TITLE } from "../constants/ask-y-page";

export const prerender = true;
---

<Layout
	title={ASK_Y_PAGE_TITLE}
	pageShell="minimal"
	disableMusicPlayer={true}
>
	<Fragment slot="head">
		<meta
			name="theme-color"
			content="#f5f4ee"
			media="(prefers-color-scheme: light)"
		/>
		<meta
			name="theme-color"
			content="#1f1c1a"
			media="(prefers-color-scheme: dark)"
		/>
	</Fragment>

	<section class="ask-y-stage">
		<div class="ask-y-backdrop" aria-hidden="true"></div>
		<div class="ask-y-shell">
			<div class="ask-y-panel">
				<header class="ask-y-topbar">
					<div class="ask-y-topbar__meta">
						<span class="ask-y-topbar__eyebrow">HiYngaの随✏️记</span>
						<h1>{ASK_Y_PAGE_TITLE}</h1>
					</div>
					<button
						type="button"
						class="ask-y-close"
						aria-label="关闭问问小Y"
						data-ask-y-close
					>
						<Icon name="material-symbols:close-rounded" />
					</button>
				</header>

				<div class="ask-y-chat-shell">
					<ProtectedRagEmbed title="问问小Y全屏对话页" />
				</div>
			</div>
		</div>
	</section>

	<style>
		:global(html, body) {
			background: var(--page-bg, oklch(0.95 0.01 var(--hue, 60)));
		}

		:global(html.dark, .dark body) {
			background: oklch(0.16 0.014 var(--hue, 60));
		}

		.ask-y-stage {
			--primary: oklch(0.7 0.14 var(--hue, 60));
			--page-bg: oklch(0.95 0.01 var(--hue, 60));
			--card-bg: white;
			--line-divider: rgb(15 23 42 / 0.08);
			--content-meta: rgb(15 23 42 / 0.7);
			--text-normal: oklch(0.25 0.02 var(--hue, 60));
			--ask-y-heading-color: oklch(0.25 0.02 var(--hue, 60));
			--ask-y-eyebrow-color: color-mix(
				in oklch,
				oklch(0.7 0.14 var(--hue, 60)) 84%,
				white 16%
			);
			--radius-large: 1rem;
			--ask-y-accent-soft: oklch(0.94 0.04 var(--hue, 60));
			--ask-y-accent-strong: oklch(0.88 0.09 var(--hue, 60));
			--ask-y-panel-shadow: color-mix(in oklch, var(--primary) 16%, transparent);
			position: fixed;
			inset: 0;
			z-index: 180;
			display: flex;
			height: 100vh;
			height: 100dvh;
			min-height: 100vh;
			min-height: 100dvh;
			width: 100%;
			overflow: hidden;
			color: var(--text-normal, oklch(0.25 0.02 var(--hue, 60)));
			background-color: var(--page-bg, oklch(0.95 0.01 var(--hue, 60)));
			background:
				radial-gradient(
					circle at 12% 2%,
					color-mix(
						in oklch,
						var(--ask-y-accent-strong, oklch(0.88 0.09 var(--hue, 60))) 34%,
						transparent
					)
					0%,
					transparent 34%
				),
				radial-gradient(
					circle at 88% 8%,
					color-mix(
						in oklch,
						var(--primary, oklch(0.7 0.14 var(--hue, 60))) 16%,
						transparent
					)
					0%,
					transparent 28%
				),
				linear-gradient(
					160deg,
					color-mix(
						in oklch,
						var(--page-bg, oklch(0.95 0.01 var(--hue, 60))) 94%,
						var(--ask-y-accent-soft, oklch(0.94 0.04 var(--hue, 60))) 6%
					)
					0%,
					color-mix(
						in oklch,
						var(--page-bg, oklch(0.95 0.01 var(--hue, 60))) 86%,
						var(--primary, oklch(0.7 0.14 var(--hue, 60))) 14%
					)
					42%,
					color-mix(
						in oklch,
						var(--page-bg, oklch(0.95 0.01 var(--hue, 60))) 96%,
						var(--ask-y-accent-soft, oklch(0.94 0.04 var(--hue, 60))) 4%
					)
					100%
				);
		}

		.ask-y-backdrop {
			position: absolute;
			inset: 0;
			background:
				radial-gradient(
					circle at 18% 18%,
					color-mix(
						in oklch,
						var(--ask-y-accent-strong, oklch(0.88 0.09 var(--hue, 60))) 26%,
						transparent
					),
					transparent 24%
				),
				radial-gradient(
					circle at 82% 12%,
					color-mix(
						in oklch,
						var(--primary, oklch(0.7 0.14 var(--hue, 60))) 18%,
						transparent
					),
					transparent 20%
				),
				radial-gradient(
					circle at 50% 100%,
					color-mix(
						in oklch,
						var(--page-bg, oklch(0.95 0.01 var(--hue, 60))) 78%,
						var(--ask-y-accent-soft, oklch(0.94 0.04 var(--hue, 60))) 22%
					),
					transparent 36%
				);
			pointer-events: none;
		}

		.ask-y-shell {
			position: relative;
			z-index: 1;
			display: flex;
			width: 100%;
			height: 100%;
			min-height: 100%;
			padding: 0.75rem;
		}

		.ask-y-panel {
			display: grid;
			grid-template-rows: auto minmax(0, 1fr);
			gap: 0.78rem;
			width: 100%;
			height: 100%;
			min-height: 100%;
			padding: 1rem;
			border: 1px solid
				color-mix(
					in oklch,
					var(--line-divider, rgb(15 23 42 / 0.08)) 74%,
					var(--primary, oklch(0.7 0.14 var(--hue, 60))) 26%
				);
			border-radius: 1.5rem;
			background-color: var(--card-bg, white);
			background:
				linear-gradient(
					180deg,
					color-mix(
						in oklch,
						var(--card-bg, white) 94%,
						var(--ask-y-accent-soft, oklch(0.94 0.04 var(--hue, 60))) 6%
					),
					color-mix(
						in oklch,
						var(--card-bg, white) 88%,
						var(--primary, oklch(0.7 0.14 var(--hue, 60))) 12%
					)
				);
			box-shadow:
				0 24px 60px
					var(
						--ask-y-panel-shadow,
						color-mix(
							in oklch,
							var(--primary, oklch(0.7 0.14 var(--hue, 60))) 16%,
							transparent
						)
					),
				inset 0 1px 0 rgb(255 255 255 / 0.55);
		}

		.ask-y-topbar {
			display: flex;
			align-items: flex-start;
			justify-content: space-between;
			gap: 1rem;
			padding: 0.1rem 0.1rem 0;
		}

		.ask-y-topbar__meta {
			min-width: 0;
		}

		.ask-y-topbar__eyebrow {
			display: inline-block;
			margin-bottom: 0.3rem;
			color: var(--ask-y-eyebrow-color);
			font-size: 0.76rem;
			font-weight: 700;
			letter-spacing: 0.08em;
			text-transform: uppercase;
		}

		.ask-y-topbar h1 {
			margin: 0;
			color: var(--ask-y-heading-color);
			font-size: clamp(1.4rem, 1.2rem + 0.7vw, 2rem);
			font-weight: 800;
			line-height: 1.08;
		}

		.ask-y-close {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 3rem;
			height: 3rem;
			flex: 0 0 auto;
			border: 1px solid
				color-mix(
					in oklch,
					var(--line-divider, rgb(15 23 42 / 0.08)) 76%,
					var(--primary, oklch(0.7 0.14 var(--hue, 60))) 24%
				);
			border-radius: 999px;
			background: color-mix(in oklch, var(--card-bg, white) 84%, transparent);
			color: var(--content-meta, rgb(15 23 42 / 0.7));
			cursor: pointer;
			box-shadow:
				0 12px 30px
				color-mix(
					in oklch,
					var(--primary, oklch(0.7 0.14 var(--hue, 60))) 8%,
					transparent
				);
			transition:
				transform 0.18s ease,
				background 0.18s ease,
				color 0.18s ease,
				border-color 0.18s ease;
		}

		.ask-y-close:hover {
			background: color-mix(
				in oklch,
				var(--card-bg, white) 92%,
				var(--primary, oklch(0.7 0.14 var(--hue, 60))) 8%
			);
			color: var(--primary, oklch(0.7 0.14 var(--hue, 60)));
			border-color: color-mix(
				in oklch,
				var(--primary, oklch(0.7 0.14 var(--hue, 60))) 42%,
				white 58%
			);
		}

		.ask-y-close:active {
			transform: scale(0.94);
		}

		.ask-y-close :global(svg) {
			width: 1.45rem;
			height: 1.45rem;
		}

		.ask-y-chat-shell {
			display: flex;
			min-width: 0;
			min-height: 0;
			height: 100%;
		}

		.ask-y-chat-shell :global(.protected-rag-embed) {
			flex: 1 1 auto;
			height: 100%;
			min-height: max(0px, calc(100dvh - 8.4rem));
			max-height: none;
			border-radius: 1.25rem;
		}

		.ask-y-chat-shell :global(.protected-rag-embed__status) {
			font-size: 1rem;
		}

		:global(body.ask-y-minimal-page) {
			overflow: hidden;
		}

		:global(html.ask-y-no-scrollbar),
		:global(body.ask-y-minimal-page) {
			overflow: hidden !important;
			scrollbar-gutter: auto !important;
			scrollbar-width: none;
			-ms-overflow-style: none;
		}

		:global(html.ask-y-no-scrollbar::-webkit-scrollbar),
		:global(body.ask-y-minimal-page::-webkit-scrollbar) {
			display: none;
			width: 0;
			height: 0;
		}

		:global(body.ask-y-minimal-page #page-height-extend),
		:global(body.ask-y-minimal-page .top-gradient-highlight),
		:global(body.ask-y-minimal-page .floating-controls-container),
		:global(body.ask-y-minimal-page #pio-container),
		:global(body.ask-y-minimal-page .music-player) {
			display: none !important;
		}

		.ask-y-stage[data-ask-y-mode="dark"] {
			--primary: oklch(0.75 0.14 var(--hue, 60));
			--page-bg: oklch(0.16 0.014 var(--hue, 60));
			--card-bg: oklch(0.23 0.015 var(--hue, 60));
			--line-divider: rgb(255 255 255 / 0.08);
			--content-meta: rgb(255 255 255 / 0.6);
			--text-normal: rgb(248 250 252 / 0.96);
			--ask-y-heading-color: rgb(248 250 252 / 0.96);
			--ask-y-eyebrow-color: rgb(248 250 252 / 0.96);
			--ask-y-accent-soft: oklch(0.34 0.03 var(--hue, 60));
			--ask-y-accent-strong: oklch(0.44 0.07 var(--hue, 60));
			--ask-y-panel-shadow: color-mix(in oklch, var(--primary) 18%, transparent);
		}

		.ask-y-stage[data-ask-y-mode="dark"] .ask-y-panel {
			border-color: color-mix(
				in oklch,
				var(--line-divider, rgb(255 255 255 / 0.08)) 68%,
				var(--primary, oklch(0.75 0.14 var(--hue, 60))) 32%
			);
			background:
				linear-gradient(
					180deg,
					color-mix(
						in oklch,
						var(--card-bg, oklch(0.23 0.015 var(--hue, 60))) 96%,
						var(--ask-y-accent-soft, oklch(0.34 0.03 var(--hue, 60))) 4%
					),
					color-mix(
						in oklch,
						var(--card-bg, oklch(0.23 0.015 var(--hue, 60))) 86%,
						var(--primary, oklch(0.75 0.14 var(--hue, 60))) 14%
					)
				);
			box-shadow:
				0 28px 82px rgb(0 0 0 / 0.34),
				inset 0 1px 0 rgb(255 255 255 / 0.05);
		}

		.ask-y-stage[data-ask-y-mode="dark"] .ask-y-close {
			border-color: color-mix(
				in oklch,
				var(--line-divider, rgb(255 255 255 / 0.08)) 64%,
				var(--primary, oklch(0.75 0.14 var(--hue, 60))) 36%
			);
			background: color-mix(
				in oklch,
				var(--card-bg, oklch(0.23 0.015 var(--hue, 60))) 84%,
				transparent
			);
			color: rgb(226 232 240 / 0.92);
			box-shadow: 0 14px 32px rgb(0 0 0 / 0.26);
		}

		.ask-y-stage[data-ask-y-mode="dark"] .ask-y-close:hover {
			background: color-mix(
				in oklch,
				var(--card-bg, oklch(0.23 0.015 var(--hue, 60))) 78%,
				var(--primary, oklch(0.75 0.14 var(--hue, 60))) 22%
			);
			color: rgb(255 255 255 / 0.98);
		}

		@media (max-width: 768px) {
			.ask-y-shell {
				padding: 0.55rem;
			}

			.ask-y-panel {
				padding: 0.8rem;
				gap: 0.55rem;
				border-radius: 1.15rem;
			}

			.ask-y-topbar {
				padding-top: 0;
			}

			.ask-y-close {
				width: 2.7rem;
				height: 2.7rem;
			}

			.ask-y-chat-shell :global(.protected-rag-embed) {
				min-height: max(0px, calc(100dvh - 7.35rem));
				border-radius: 0.95rem;
			}
		}

		@media (max-width: 520px) {
			.ask-y-shell {
				padding: 0.35rem;
			}

			.ask-y-panel {
				padding: 0.68rem;
				gap: 0.5rem;
				border-radius: 0.95rem;
			}

			.ask-y-topbar__eyebrow {
				font-size: 0.7rem;
			}

			.ask-y-close {
				width: 2.5rem;
				height: 2.5rem;
			}

			.ask-y-chat-shell :global(.protected-rag-embed) {
				min-height: max(0px, calc(100dvh - 6.4rem));
				border-radius: 0.85rem;
			}
		}
	</style>

	<script is:inline>
		(() => {
			const doc = document;
			const body = doc.body;
			const root = doc.documentElement;
			const stage = doc.querySelector(".ask-y-stage");
			const closeButton = doc.querySelector("[data-ask-y-close]");
			const previousPath = doc.referrer
				? new URL(doc.referrer).pathname
				: "";

			body.classList.add("ask-y-minimal-page");
			root.classList.add("ask-y-no-scrollbar");

			const syncAskYThemeMode = () => {
				if (!(stage instanceof HTMLElement)) {
					return;
				}

				stage.dataset.askYMode = doc.documentElement.classList.contains("dark")
					? "dark"
					: "light";
			};

			syncAskYThemeMode();
			const themeObserver = new MutationObserver(syncAskYThemeMode);
			themeObserver.observe(doc.documentElement, {
				attributes: true,
				attributeFilter: ["class"],
			});

			const fallbackPath =
				previousPath &&
				previousPath !== "/ask-y/" &&
				previousPath.startsWith("/")
					? previousPath
					: "/";

			const closeAskYPage = () => {
				if (window.history.length > 1 && previousPath && previousPath !== "/ask-y/") {
					window.history.back();
					return;
				}

				window.location.href = fallbackPath;
			};

			closeButton?.addEventListener("click", closeAskYPage);

			window.addEventListener("keydown", (event) => {
				if (event.key === "Escape") {
					closeAskYPage();
				}
			});

			document.querySelectorAll('[data-ask-y-full-page="true"]').forEach((link) => {
				link.addEventListener("click", () => {
					body.classList.remove("ask-y-minimal-page");
				});
			});

			window.addEventListener("pagehide", () => {
				themeObserver.disconnect();
				body.classList.remove("ask-y-minimal-page");
				root.classList.remove("ask-y-no-scrollbar");
			});
		})();
	</script>
</Layout>
