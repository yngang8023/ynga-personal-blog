---
import { Icon } from "astro-icon/components";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";

interface Props {
	id: string;
	name?: string;
	isCollapsed?: boolean;
	collapsedHeight?: string;
	collapsedRows?: number;
	class?: string;
	style?: string;
}
const { id, name, isCollapsed, collapsedHeight, collapsedRows, style } = Astro.props;
const className = Astro.props.class;
const collapsible = Boolean(isCollapsed && collapsedHeight);
const showMoreLabel = i18n(I18nKey.showMore);
const showLessLabel = i18n(I18nKey.showLess);
const collapseRows = Number.isFinite(Number(collapsedRows))
	? Math.max(Number(collapsedRows), 1)
	: 3;
---

<widget-layout
	data-collapsible={String(collapsible)}
	data-collapsed-height={collapsedHeight ?? ""}
	data-collapsed-rows={String(collapseRows)}
	class={"pb-4 card-base " + className}
	style={style}
>
	{
		name && (
			<div
				class="font-bold transition text-lg text-neutral-900 dark:text-neutral-100 relative ml-8 mt-4 mb-2 flex items-center
        before:w-1 before:h-4 before:rounded-md before:bg-[var(--primary)]
        before:absolute before:left-[-16px] before:top-[5.5px]"
			>
				{name}
				<slot name="title-icon" />
			</div>
		)
	}
	<div
		id={id}
		class:list={[
			"collapse-wrapper px-4 overflow-hidden",
			{ collapsed: collapsible, collapsible },
		]}
	>
		<slot />
	</div>
	{
		collapsible && (
			<div class="expand-btn px-4">
				<button
					type="button"
					class="btn-plain rounded-lg w-full h-9 widget-toggle-btn"
					aria-controls={id}
					aria-expanded="false"
					aria-label={showMoreLabel}
					data-label-expand={showMoreLabel}
					data-label-collapse={showLessLabel}
					data-expanded="false"
				>
					<div class="text-[var(--primary)] flex items-center justify-center gap-1.5">
						<Icon
							name="material-symbols:keyboard-arrow-down-rounded"
							class="text-[1.5rem] widget-toggle-icon"
						/>
						<span class="widget-toggle-label">{showMoreLabel}</span>
					</div>
				</button>
			</div>
		)
	}
</widget-layout>

<style define:vars={{ collapsedHeight }}>
	widget-layout {
		display: block;
		width: 100%;
		min-width: 0;
	}

	.collapse-wrapper.collapsible {
		transition: max-height 300ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.collapse-wrapper.collapsed {
		max-height: var(--collapsedHeight);
	}

	.widget-toggle-icon {
		transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.widget-toggle-btn[data-expanded="true"] .widget-toggle-icon {
		transform: rotate(180deg);
	}

	.expand-btn {
		margin-top: 0.7rem;
		padding-bottom: 0.2rem;
	}

	@media (max-width: 640px) {
		.expand-btn {
			margin-top: 0.6rem;
			padding-bottom: 0.125rem;
		}
	}
</style>

<script>
	class WidgetLayout extends HTMLElement {
		wrapper: HTMLElement | null = null;
		button: HTMLButtonElement | null = null;
		label: HTMLElement | null = null;
		collapsedHeight = "7.5rem";
		collapsedRows = 3;
		isExpanded = false;
		shouldCollapse = false;
		handleToggle: (() => void) | null = null;
		handleTransitionEnd: ((event: TransitionEvent) => void) | null = null;
		handleResize: (() => void) | null = null;
	resizeObserver: ResizeObserver | null = null;
	toggleContainer: HTMLElement | null = null;

		connectedCallback() {
			if (this.dataset.initialized === "true") {
				return;
			}
			this.dataset.initialized = "true";

			if (this.dataset.collapsible !== "true") {
				return;
			}

			this.wrapper = this.querySelector(".collapse-wrapper");
			this.button = this.querySelector(".widget-toggle-btn");
			this.label = this.querySelector(".widget-toggle-label");
			this.toggleContainer = this.querySelector(".expand-btn");
			this.collapsedHeight =
				this.dataset.collapsedHeight && this.dataset.collapsedHeight !== ""
					? this.dataset.collapsedHeight
					: "7.5rem";
			this.collapsedRows = Number.parseInt(this.dataset.collapsedRows || "3", 10) || 3;
			this.isExpanded = false;

			if (!this.wrapper || !this.button || !this.label) {
				return;
			}

			this.handleToggle = () => this.toggle();
			this.handleTransitionEnd = () => {
				if (this.isExpanded && this.wrapper && this.shouldCollapse) {
					this.wrapper.style.maxHeight = "none";
				}
			};
			this.handleResize = () => this.refreshCollapseState();

			this.button.addEventListener("click", this.handleToggle);
			this.wrapper.addEventListener(
				"transitionend",
				this.handleTransitionEnd,
			);
			this.resizeObserver = new ResizeObserver(this.handleResize);
			this.resizeObserver.observe(this.wrapper);
			window.addEventListener("resize", this.handleResize);
			this.refreshCollapseState();
		}

		disconnectedCallback() {
			if (this.handleToggle) {
				this.button?.removeEventListener("click", this.handleToggle);
			}
			if (this.handleTransitionEnd) {
				this.wrapper?.removeEventListener(
					"transitionend",
					this.handleTransitionEnd,
				);
			}
			if (this.handleResize) {
				window.removeEventListener("resize", this.handleResize);
			}
			this.resizeObserver?.disconnect();
			this.dataset.initialized = "false";
		}

		getCollapseItems() {
			if (!this.wrapper) {
				return [];
			}

			const directChildren = Array.from(this.wrapper.children).filter(
				(node): node is HTMLElement => node instanceof HTMLElement,
			);

			if (directChildren.length === 1) {
				const container = directChildren[0];
				const containerStyle = getComputedStyle(container);
				if (
					containerStyle.display.includes("flex") ||
					containerStyle.display.includes("grid")
				) {
					const nestedItems = Array.from(container.children).filter(
						(node): node is HTMLElement =>
							node instanceof HTMLElement && node.getClientRects().length > 0,
					);
					if (nestedItems.length > 0) {
						return nestedItems;
					}
				}
			}

			return directChildren.filter((node) => node.getClientRects().length > 0);
		}

		measureCollapseRows() {
			if (!this.wrapper) {
				return {
					rowCount: 0,
					collapsedHeightPx: 0,
				};
			}

			const items = this.getCollapseItems();
			if (items.length === 0) {
				return {
					rowCount: 0,
					collapsedHeightPx: 0,
				};
			}

			const wrapperRect = this.wrapper.getBoundingClientRect();
			const rows: Array<{ top: number; bottom: number }> = [];

			for (const item of items) {
				const rect = item.getBoundingClientRect();
				if (rect.width <= 0 || rect.height <= 0) {
					continue;
				}

				const top = Math.round((rect.top - wrapperRect.top) * 10) / 10;
				const bottom = rect.bottom - wrapperRect.top;
				const existing = rows.find((row) => Math.abs(row.top - top) < 1);

				if (existing) {
					existing.bottom = Math.max(existing.bottom, bottom);
				} else {
					rows.push({ top, bottom });
				}
			}

			rows.sort((a, b) => a.top - b.top);

			if (rows.length <= this.collapsedRows) {
				return {
					rowCount: rows.length,
					collapsedHeightPx: 0,
				};
			}

			const cutoffRow = rows[this.collapsedRows - 1];
			return {
				rowCount: rows.length,
				collapsedHeightPx: Math.ceil(cutoffRow.bottom + 2),
			};
		}

		getCollapsedHeightPx() {
			if (!this.wrapper) {
				return 0;
			}

			const computedStyle = getComputedStyle(this.wrapper);
			const rootFontSize = parseFloat(
				getComputedStyle(document.documentElement).fontSize,
			);
			const value = this.collapsedHeight.trim();

			if (value.endsWith("rem")) {
				return parseFloat(value) * rootFontSize;
			}
			if (value.endsWith("px")) {
				return parseFloat(value);
			}

			const resolvedMaxHeight = parseFloat(computedStyle.maxHeight);
			return Number.isFinite(resolvedMaxHeight) ? resolvedMaxHeight : 0;
		}

		refreshCollapseState() {
			if (!this.wrapper || !this.button || !this.label) {
				return;
			}

			const previousMaxHeight = this.wrapper.style.maxHeight;
			this.wrapper.style.maxHeight = "none";

			const contentHeight = this.wrapper.scrollHeight;
			const { rowCount, collapsedHeightPx } = this.measureCollapseRows();
			this.shouldCollapse = rowCount > this.collapsedRows;
			if (this.toggleContainer) {
				this.toggleContainer.hidden = !this.shouldCollapse;
			}

			if (!this.shouldCollapse) {
				this.isExpanded = false;
				this.wrapper.classList.remove("collapsed", "collapsible");
				this.wrapper.style.maxHeight = "none";
				this.syncState();
				return;
			}

			this.wrapper.classList.add("collapsible");
			if (!this.isExpanded) {
				this.wrapper.classList.add("collapsed");
			}
			const fallbackHeight = this.getCollapsedHeightPx() || contentHeight;
			const targetCollapsedHeight = collapsedHeightPx || fallbackHeight;
			this.wrapper.style.maxHeight = this.isExpanded
				? previousMaxHeight === "none" || previousMaxHeight === ""
					? `${contentHeight}px`
					: previousMaxHeight
				: `${targetCollapsedHeight}px`;
			this.syncState();
		}

		syncState() {
			if (!this.button || !this.label || !this.wrapper) {
				return;
			}

			const expandLabel = this.button.dataset.labelExpand || "";
			const collapseLabel = this.button.dataset.labelCollapse || "";
			const currentLabel =
				this.shouldCollapse && this.isExpanded ? collapseLabel : expandLabel;

			this.button.dataset.expanded = String(this.shouldCollapse && this.isExpanded);
			this.button.setAttribute(
				"aria-expanded",
				String(this.shouldCollapse && this.isExpanded),
			);
			this.button.setAttribute("aria-label", currentLabel);
			this.label.textContent = currentLabel;
			this.wrapper.classList.toggle(
				"collapsed",
				this.shouldCollapse && !this.isExpanded,
			);
		}

		toggle() {
			if (!this.wrapper || !this.button || !this.shouldCollapse) {
				return;
			}

			const { wrapper } = this;

			if (this.isExpanded) {
				wrapper.style.maxHeight = `${wrapper.scrollHeight}px`;
				requestAnimationFrame(() => {
					this.isExpanded = false;
					this.syncState();
					wrapper.style.maxHeight = this.collapsedHeight;
				});
				return;
			}

			if (wrapper.style.maxHeight === "none") {
				wrapper.style.maxHeight = this.collapsedHeight;
			}

			requestAnimationFrame(() => {
				this.isExpanded = true;
				this.syncState();
				wrapper.style.maxHeight = `${wrapper.scrollHeight}px`;
			});
		}
	}

	if (!customElements.get("widget-layout")) {
		customElements.define("widget-layout", WidgetLayout);
	}
</script>
