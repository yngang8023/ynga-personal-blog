---
import { umamiConfig } from "@/config";
import {
	DEFAULT_UMAMI_PROXY_BASE_PATH,
	DEFAULT_UMAMI_STATS_CACHE_TTL_MS,
} from "@/config";

const runtimeConfig = JSON.stringify({
	shareUrl: umamiConfig.shareUrl,
	proxyBasePath:
		umamiConfig.proxyBasePath || DEFAULT_UMAMI_PROXY_BASE_PATH,
	statsCacheTtlMs:
		umamiConfig.statsCacheTtlMs ?? DEFAULT_UMAMI_STATS_CACHE_TTL_MS,
});
---

{
	umamiConfig.enable && (
		<>
			<script
				type="application/json"
				is:inline
				id="mizuki-umami-runtime-config"
				set:html={runtimeConfig}
			/>
			<script>
				import { createUmamiStatsClient } from "./umami-runtime-utils.js";

				(() => {
					type UmamiRuntimeConfig = {
						shareUrl?: string;
						proxyBasePath?: string;
						statsCacheTtlMs?: number;
					};

					const RUNTIME_KEY = "__mizukiUmamiRuntimeReady";
					if (window[RUNTIME_KEY]) {
						return;
					}
					window[RUNTIME_KEY] = true;

					const configElement = document.getElementById(
						"mizuki-umami-runtime-config",
					);
					if (!configElement?.textContent) {
						return;
					}

					let runtimeConfig: UmamiRuntimeConfig;
					try {
						runtimeConfig = JSON.parse(
							configElement.textContent,
						) as UmamiRuntimeConfig;
					} catch (error) {
						console.error("[Umami] 运行时配置解析失败:", error);
						return;
					}

					const runtimeShareUrl = runtimeConfig.shareUrl;
					if (!runtimeShareUrl) {
						return;
					}

					const client = createUmamiStatsClient({
						shareUrl: runtimeShareUrl,
						proxyBasePath: runtimeConfig.proxyBasePath,
						statsCacheTtlMs:
							Number(runtimeConfig.statsCacheTtlMs) || 3000,
					});

					window.oddmisc = {
						...(window.oddmisc || {}),
						getStats: (path, options) =>
							client.getStats(path, options),
						getSiteStats: (options) =>
							client.getSiteStats(options),
						getPageStats: (path, options) =>
							client.getPageStats(path, options),
						getArticleTotalViews: (articlePaths, options) =>
							client.getArticleTotalViews(
								articlePaths,
								options,
							),
						clearCache: () => client.clearCache(),
						umami: {
							clearCache: () => client.clearCache(),
						},
					};

					window.dispatchEvent(
						new CustomEvent("mizuki:umami-ready"),
					);
				})();
			</script>
		</>
	)
}
