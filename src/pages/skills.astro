---
import { PageHeader } from "@components/features/page-header";
import { SectionTitle } from "@components/features/section-title";
import { SkillCard } from "@components/features/skills";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import type { MarkdownHeading } from "astro";

import { siteConfig } from "../config";
import type { Skill } from "../data/skills";
import { getSkillExperience, skillsData } from "../data/skills";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

if (!siteConfig.featurePages.skills) {
	return Astro.redirect("/404/");
}

const categoryMeta = [
	{
		key: "backend",
		label: i18n(I18nKey.skillsBackend),
		color: "#8B5CF6",
	},
	{
		key: "database",
		label: i18n(I18nKey.skillsDatabase),
		color: "#10B981",
	},
	{
		key: "tools",
		label: i18n(I18nKey.skillsTools),
		color: "#F59E0B",
	},
	{
		key: "frontend",
		label: i18n(I18nKey.skillsFrontend),
		color: "#3B82F6",
	},
	{
		key: "other",
		label: i18n(I18nKey.skillsOther),
		color: "#EC4899",
	},
] as const;

const levelMeta = [
	{
		key: "expert",
		label: i18n(I18nKey.skillsExpert),
		color: "#EF4444",
	},
	{
		key: "advanced",
		label: i18n(I18nKey.skillsAdvanced),
		color: "#F97316",
	},
	{
		key: "intermediate",
		label: i18n(I18nKey.skillsIntermediate),
		color: "#FACC15",
	},
	{
		key: "beginner",
		label: i18n(I18nKey.skillsBeginner),
		color: "#22C55E",
	},
] as const;

const levelRank: Record<Skill["level"], number> = {
	expert: 4,
	advanced: 3,
	intermediate: 2,
	beginner: 1,
};

const sortedSkills = [...skillsData].sort((a, b) => {
	const levelDiff = levelRank[b.level] - levelRank[a.level];
	if (levelDiff !== 0) {
		return levelDiff;
	}

	const monthDiff =
		getSkillExperience(b).totalMonths - getSkillExperience(a).totalMonths;
	if (monthDiff !== 0) {
		return monthDiff;
	}

	return a.name.localeCompare(b.name, "zh-CN");
});

const totalSkills = sortedSkills.length;
const advancedSkillCount = sortedSkills.filter(
	(skill) => levelRank[skill.level] >= 3,
).length;

const groupedSkills = categoryMeta
	.map((category) => {
		const items = sortedSkills.filter((skill) => skill.category === category.key);
		return {
			...category,
			items,
			count: items.length,
			percentage: totalSkills > 0 ? (items.length / totalSkills) * 100 : 0,
		};
	})
	.filter((group) => group.count > 0);

const levelStats = levelMeta.map((level) => {
	const count = sortedSkills.filter((skill) => skill.level === level.key).length;
	return {
		...level,
		count,
		percentage: totalSkills > 0 ? (count / totalSkills) * 100 : 0,
	};
});

const levelStatMap = Object.fromEntries(
	levelStats.map((stat) => [stat.key, stat]),
) as Record<
	(typeof levelMeta)[number]["key"],
	(typeof levelStats)[number]
>;

const displayLevelStats = [
	{
		key: "advanced",
		label: i18n(I18nKey.skillsAdvanced),
		color: levelStatMap.advanced.color,
		count: levelStatMap.expert.count + levelStatMap.advanced.count,
		percentage:
			totalSkills > 0
				? ((levelStatMap.expert.count + levelStatMap.advanced.count) /
						totalSkills) *
					100
				: 0,
	},
	{
		key: "intermediate",
		label: i18n(I18nKey.skillsIntermediate),
		color: levelStatMap.intermediate.color,
		count: levelStatMap.intermediate.count,
		percentage: levelStatMap.intermediate.percentage,
	},
	{
		key: "beginner",
		label: i18n(I18nKey.skillsBeginner),
		color: levelStatMap.beginner.color,
		count: levelStatMap.beginner.count,
		percentage: levelStatMap.beginner.percentage,
	},
	{
		key: "novice",
		label: "入门",
		color: "#0EA5E9",
		count: 0,
		percentage: 0,
	},
];

let donutOffset = 0;
const donutStops = displayLevelStats
	.map((stat) => {
		const start = donutOffset;
		const end = donutOffset + stat.percentage;
		donutOffset = end;
		return `${stat.color} ${start}% ${end}%`;
	})
	.join(", ");

const donutStyle = `background: conic-gradient(${donutStops || "#E5E7EB 0% 100%"});`;

const title = i18n(I18nKey.skills);
const subtitle = i18n(I18nKey.skillsSubtitle);
const heroSpotlight = ["ai-agent", "java", "spring-boot"]
	.map((id) => sortedSkills.find((skill) => skill.id === id))
	.filter((skill): skill is Skill => !!skill);
const skillHeadings: MarkdownHeading[] = groupedSkills.map((group) => ({
	depth: 2,
	slug: `skills-${group.key}`,
	text: group.label,
}));
const heroTags = [
	"AI Agent",
	"Java 后端",
	"智能体实践",
];
const levelLabelMap = Object.fromEntries(
	levelMeta.map((level) => [level.key, level.label]),
) as Record<Skill["level"], string>;

const formatExperience = (skill: Pick<Skill, "startedAt">) => {
	const { years, months } = getSkillExperience(skill);
	const parts: string[] = [];
	if (years > 0) {
		parts.push(`${years} 年`);
	}
	if (months > 0) {
		parts.push(`${months} 个月`);
	}
	return parts.join(" ") || "持续学习中";
};
---

<MainGridLayout title={title} description={subtitle} headings={skillHeadings}>
	<script>
		import("../scripts/right-sidebar-layout.js");
		import { loadIconify } from "../utils/icon-loader";

		loadIconify().catch((error) => {
			console.error("Failed to load Iconify:", error);
		});
	</script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-visible relative min-h-32"
		data-skills-filter-root
		data-active-filter="all"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={subtitle} />

			<section class="skills-hero" data-skills-hero>
				<div class="skills-hero-main">
					<span class="skills-hero-eyebrow">AI Agent Focus</span>
					<h2 class="skills-hero-title">
						把AI Agent当成当前重点深挖的方向，持续把智能体能力接到真实项目里。
					</h2>
					<p class="skills-hero-description">
						现在不只是继续打磨 Java 后端与常见工程化能力，也在持续探索
						AI Agent、工具调用、工作流编排、提示词设计以及和后端服务协同落地的实现方式，
						希望把这些能力慢慢沉淀成真正可用、可维护、可持续演进的项目实践。
					</p>

					<div class="skills-hero-tags">
						{
							heroTags.map((tag) => (
								<span class="skills-hero-tag">{tag}</span>
							))
						}
					</div>
				</div>

				<div class="skills-hero-spotlights">
					{
						heroSpotlight.map((skill) => (
							<article
								class="skills-spotlight-card"
								style={`--spotlight:${skill.color || "#3B82F6"};`}
							>
								<div class="skills-spotlight-top">
									<div>
										<p class="skills-spotlight-kicker">
											{levelLabelMap[skill.level]}
										</p>
										<h3 class="skills-spotlight-name">{skill.name}</h3>
									</div>
									<span
										class="skills-spotlight-exp"
										data-skill-experience
										data-skill-started-at={skill.startedAt}
										data-skill-years-label="年"
										data-skill-months-label="个月"
										data-skill-ongoing-label="持续学习中"
									>
										{formatExperience(skill)}
									</span>
								</div>
								<p class="skills-spotlight-text">{skill.description}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="skills-overview-grid">
				<div class="skills-panel">
					<div class="skills-panel-head">
						<span class="skills-panel-dot bg-[var(--primary)]"></span>
						<h2 class="skills-panel-title">按等级分布</h2>
					</div>

					<div
						class="skills-donut-layout"
						style="display:grid;grid-template-columns:1fr;align-items:center;gap:1.45rem;width:min(100%,46rem);margin-inline:auto;"
					>
						<div
							class="skills-donut-shell"
							style="display:flex;justify-content:center;align-items:center;width:100%;padding:1rem 0 0.35rem;"
						>
							<div class="skills-donut-ring" style={donutStyle}>
								<div class="skills-donut-core">
									<strong>{totalSkills}</strong>
									<span>项技能</span>
								</div>
							</div>
						</div>

						<div
							class="skills-legend-wrap"
							style="width:100%;max-width:46rem;margin-inline:auto;padding-inline:clamp(0.5rem,1.4vw,1rem);box-sizing:border-box;"
						>
							<div
								class="skills-legend-grid"
								style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1.1rem;width:100%;"
							>
								{
									displayLevelStats.map((stat) => (
										<div class="skills-legend-item">
											<div class="skills-legend-top">
												<span class="skills-legend-title">{stat.label}</span>
												<strong class="skills-legend-count">{stat.count}</strong>
											</div>
											<div class="skills-legend-bottom">
												<div class="skills-legend-signal">
													<span
														class="skills-legend-dot"
														style={`background:${stat.color};`}
													></span>
													<span class="skills-legend-note">当前分布</span>
												</div>
												<span class="skills-legend-percent">
													{Math.round(stat.percentage)}%
												</span>
											</div>
										</div>
									))
								}
							</div>
						</div>
					</div>
				</div>

				<div class="skills-panel">
					<div class="skills-panel-head">
						<span class="skills-panel-dot bg-[oklch(0.7_0.22_300)]"></span>
						<h2 class="skills-panel-title">按分类分布</h2>
					</div>

					<div class="skills-category-bars">
						{
							groupedSkills.map((group) => (
								<div class="skills-category-bar-item">
									<div class="skills-category-bar-head">
										<div class="skills-category-bar-label">
											<span>{group.label}</span>
											<span class="skills-count-chip">{group.count}</span>
										</div>
										<span class="skills-category-bar-percent">
											{Math.round(group.percentage)}%
										</span>
									</div>
									<div class="skills-category-track">
										<div
											class="skills-category-fill"
											style={`width:${group.percentage}%; background:${group.color};`}
										></div>
									</div>
								</div>
							))
						}
					</div>

					<div class="skills-stats-grid">
						<div class="skills-stat-card bg-[linear-gradient(135deg,rgba(59,130,246,0.12),rgba(125,211,252,0.16))] border-[rgba(59,130,246,0.18)]">
							<span class="skills-stat-label">熟练掌握</span>
							<strong class="skills-stat-value text-[oklch(0.58_0.2_255)]">
								{advancedSkillCount}
							</strong>
							<span class="skills-stat-sub">高级及以上</span>
						</div>
						<div class="skills-stat-card bg-[linear-gradient(135deg,rgba(34,197,94,0.12),rgba(134,239,172,0.18))] border-[rgba(34,197,94,0.18)]">
							<span class="skills-stat-label">总技能数</span>
							<strong class="skills-stat-value text-[oklch(0.62_0.19_145)]">
								{totalSkills}
							</strong>
							<span class="skills-stat-sub">技能展示</span>
						</div>
					</div>

					<div class="skills-focus-strip">
						<div class="skills-focus-item">
							<span class="skills-focus-label">主线方向</span>
							<strong class="skills-focus-value">Java 后端开发</strong>
						</div>
						<div class="skills-focus-item">
							<span class="skills-focus-label">当前兴趣</span>
							<strong class="skills-focus-value">AI Agent / 智能体实践</strong>
						</div>
					</div>
				</div>
			</section>

			<nav
				class="skills-anchor-nav"
				aria-label="技能分类筛选"
				data-skills-filter-nav
			>
				<button
					type="button"
					class="skills-anchor-chip is-active"
					style="--chip-accent: var(--primary);"
					data-filter-chip="all"
					aria-pressed="true"
				>
					<span class="skills-anchor-dot"></span>
					<span>全部</span>
					<span class="skills-anchor-count">{totalSkills}</span>
				</button>
				{
					groupedSkills.map((group) => (
						<button
							type="button"
							class="skills-anchor-chip"
							style={`--chip-accent:${group.color};`}
							data-filter-chip={group.key}
							aria-pressed="false"
						>
							<span class="skills-anchor-dot"></span>
							<span>{group.label}</span>
							<span class="skills-anchor-count">{group.count}</span>
						</button>
					))
				}
			</nav>

			<section class="skills-sections">
				{
					groupedSkills.map((group) => (
						<section
							id={`skills-${group.key}`}
							class="skills-category-section"
							data-filter-section={group.key}
						>
							<SectionTitle title={group.label} count={group.count} />
							<div class="skills-category-grid">
								{group.items.map((skill) => <SkillCard skill={skill} />)}
							</div>
						</section>
					))
				}
			</section>
		</div>
	</div>
</MainGridLayout>

<script is:inline>
	(() => {
		const initSkillsFilter = (root) => {
			if (!(root instanceof HTMLElement)) return;

			const nav = root.querySelector("[data-skills-filter-nav]");
			if (!(nav instanceof HTMLElement) || nav.dataset.filterBound === "true") {
				return;
			}

			const chips = Array.from(
				root.querySelectorAll("[data-filter-chip]"),
			).filter((chip) => chip instanceof HTMLButtonElement);
			const sections = Array.from(
				root.querySelectorAll("[data-filter-section]"),
			).filter((section) => section instanceof HTMLElement);

			if (chips.length === 0 || sections.length === 0) {
				return;
			}

			const applyFilter = (filterKey) => {
				const nextFilter = filterKey || "all";
				root.dataset.activeFilter = nextFilter;

				chips.forEach((chip) => {
					const isActive = chip.dataset.filterChip === nextFilter;
					chip.classList.toggle("is-active", isActive);
					chip.setAttribute("aria-pressed", isActive ? "true" : "false");
				});

				sections.forEach((section) => {
					const shouldShow =
						nextFilter === "all" ||
						section.dataset.filterSection === nextFilter;
					section.toggleAttribute("hidden", !shouldShow);
				});

				requestAnimationFrame(() => {
					initSkillDescriptionDetails();
					updateSkillDescriptionPlacement();
				});
			};

			nav.addEventListener("click", (event) => {
				const target = event.target;
				if (!(target instanceof Element)) return;

				const chip = target.closest("[data-filter-chip]");
				if (!(chip instanceof HTMLButtonElement)) return;

				const selectedFilter = chip.dataset.filterChip || "all";
				const currentFilter = root.dataset.activeFilter || "all";
				const nextFilter =
					selectedFilter === currentFilter && selectedFilter !== "all"
						? "all"
						: selectedFilter;

				applyFilter(nextFilter);
			});

			nav.dataset.filterBound = "true";
			applyFilter(root.dataset.activeFilter || "all");
		};

		const bootSkillsFilter = () => {
			document
				.querySelectorAll("[data-skills-filter-root]")
				.forEach((root) => initSkillsFilter(root));
		};

		const updateSkillsHeroLayout = () => {
			document.querySelectorAll("[data-skills-hero]").forEach((hero) => {
				if (!(hero instanceof HTMLElement)) return;

				const main = hero.querySelector(".skills-hero-main");
				const mainWidth =
					main instanceof HTMLElement ? main.clientWidth : hero.clientWidth;
				const heroWidth = hero.clientWidth;

				let layout = "compact";
				if (mainWidth >= 580 || heroWidth >= 1240) {
					layout = "wide";
				} else if (mainWidth >= 460 || heroWidth >= 980) {
					layout = "balanced";
				}

				hero.dataset.heroLayout = layout;
			});
		};

		const observeSkillsHeroLayout = () => {
			if (typeof ResizeObserver === "undefined") {
				updateSkillsHeroLayout();
				return;
			}

			window.__skillsHeroLayoutObserver?.disconnect();

			const observer = new ResizeObserver(() => {
				updateSkillsHeroLayout();
			});

			document.querySelectorAll("[data-skills-hero]").forEach((hero) => {
				if (!(hero instanceof HTMLElement)) return;
				observer.observe(hero);

				const main = hero.querySelector(".skills-hero-main");
				if (main instanceof HTMLElement) {
					observer.observe(main);
				}
			});

			window.__skillsHeroLayoutObserver = observer;
			updateSkillsHeroLayout();
		};

		const parseSkillStartedAt = (startedAt) => {
			const [yearText, monthText, dayText = "1"] = startedAt.split("-");
			const year = Number(yearText);
			const month = Number(monthText);
			const day = Number(dayText);

			if (
				!Number.isFinite(year) ||
				!Number.isFinite(month) ||
				!Number.isFinite(day)
			) {
				return null;
			}

			return { year, month, day };
		};

		const getSkillExperienceFromDate = (startedAt, now = new Date()) => {
			const parsed = parseSkillStartedAt(startedAt);
			if (!parsed) {
				return { years: 0, months: 0 };
			}

			let totalMonths =
				(now.getFullYear() - parsed.year) * 12 +
				(now.getMonth() + 1 - parsed.month);

			if (now.getDate() < parsed.day) {
				totalMonths -= 1;
			}

			totalMonths = Math.max(0, totalMonths);

			return {
				years: Math.floor(totalMonths / 12),
				months: totalMonths % 12,
			};
		};

		const updateRuntimeSkillExperience = () => {
			document.querySelectorAll("[data-skill-experience]").forEach((element) => {
				if (!(element instanceof HTMLElement)) return;

				const startedAt = element.dataset.skillStartedAt;
				if (!startedAt) return;

				const yearsLabel = element.dataset.skillYearsLabel || "年";
				const monthsLabel = element.dataset.skillMonthsLabel || "个月";
				const ongoingLabel =
					element.dataset.skillOngoingLabel || "持续学习中";
				const { years, months } = getSkillExperienceFromDate(startedAt);
				const parts = [];

				if (years > 0) {
					parts.push(`${years} ${yearsLabel}`);
				}

				if (months > 0) {
					parts.push(`${months} ${monthsLabel}`);
				}

				element.textContent = parts.join(" ") || ongoingLabel;
			});
		};

		const initSkillDescriptionDetails = () => {
			document.querySelectorAll("[data-skill-details]").forEach((details) => {
				if (!(details instanceof HTMLDetailsElement)) return;

				const preview = details.querySelector("[data-skill-preview]");
				const hint = details.querySelector("[data-skill-hint]");
				const card = details.closest(".skill-card");
				if (!(preview instanceof HTMLElement) || !(hint instanceof HTMLElement)) {
					return;
				}

				const isTruncated =
					preview.scrollHeight - preview.clientHeight > 1 ||
					preview.scrollWidth - preview.clientWidth > 1;

				details.dataset.truncated = isTruncated ? "true" : "false";
				if (card instanceof HTMLElement) {
					card.setAttribute("data-has-popover", isTruncated ? "true" : "false");
				}
				hint.hidden = !isTruncated;
				details.toggleAttribute("data-disabled", !isTruncated);

				if (!isTruncated) {
					details.open = false;
				}
			});
		};

		const updateSkillDescriptionPlacement = () => {
			document.querySelectorAll("[data-skill-details]").forEach((details) => {
				if (!(details instanceof HTMLDetailsElement)) return;

				const popover = details.querySelector(".skill-description-popover");
				if (!(popover instanceof HTMLElement)) return;

				if (details.dataset.truncated !== "true") {
					details.dataset.popoverPlacement = "bottom";
					return;
				}

				details.dataset.popoverPlacement = "bottom";

				const triggerRect = details.getBoundingClientRect();
				const popoverHeight = Math.max(
					popover.offsetHeight,
					popover.scrollHeight,
					0,
				);
				const gap = 20;
				const viewportHeight = window.innerHeight;
				const spaceAbove = triggerRect.top;
				const spaceBelow = viewportHeight - triggerRect.bottom;
				const needsTopPlacement =
					spaceBelow < popoverHeight + gap && spaceAbove > spaceBelow;

				details.dataset.popoverPlacement = needsTopPlacement
					? "top"
					: "bottom";
			});
		};

		const initSkillDetailsAccordion = () => {
			document.querySelectorAll("[data-skill-details]").forEach((details) => {
				if (!(details instanceof HTMLDetailsElement)) return;
				if (details.dataset.accordionBound === "true") return;

				details.addEventListener("click", (event) => {
					if (details.dataset.truncated === "true") return;
					event.preventDefault();
				});

				details.addEventListener("keydown", (event) => {
					if (details.dataset.truncated === "true") return;
					if (event.key === "Enter" || event.key === " ") {
						event.preventDefault();
					}
				});

				details.addEventListener("mouseenter", () => {
					if (details.dataset.truncated !== "true") return;
					updateSkillDescriptionPlacement();
				});

				details.addEventListener("focusin", () => {
					if (details.dataset.truncated !== "true") return;
					updateSkillDescriptionPlacement();
				});

				details.addEventListener("toggle", () => {
					if (!details.open) return;
					if (details.dataset.truncated !== "true") {
						details.open = false;
						return;
					}

					document.querySelectorAll("[data-skill-details]").forEach((other) => {
						if (!(other instanceof HTMLDetailsElement)) return;
						if (other === details) return;
						other.open = false;
					});

					updateSkillDescriptionPlacement();
				});

				details.dataset.accordionBound = "true";
			});

			if (document.documentElement.dataset.skillDetailsOutsideBound === "true") {
				return;
			}

			document.addEventListener("click", (event) => {
				const target = event.target;
				if (!(target instanceof Element)) return;
				if (target.closest("[data-skill-details]")) return;

				document.querySelectorAll("[data-skill-details]").forEach((details) => {
					if (details instanceof HTMLDetailsElement) {
						details.open = false;
					}
				});
			});

			document.documentElement.dataset.skillDetailsOutsideBound = "true";
		};

		const bootSkillsPageUi = () => {
			bootSkillsFilter();
			requestAnimationFrame(() => {
				updateSkillsHeroLayout();
				observeSkillsHeroLayout();
				updateRuntimeSkillExperience();
				initSkillDescriptionDetails();
				updateSkillDescriptionPlacement();
				initSkillDetailsAccordion();
			});
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", bootSkillsPageUi, {
				once: true,
			});
		} else {
			bootSkillsPageUi();
		}

		window.addEventListener("resize", () => {
			updateSkillsHeroLayout();
			updateRuntimeSkillExperience();
			initSkillDescriptionDetails();
			updateSkillDescriptionPlacement();
		});
		window.addEventListener("load", () => {
