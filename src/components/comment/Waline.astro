---
import { Icon } from "astro-icon/components";

import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	path: string;
}

const { path } = Astro.props;
---

<div class="waline-comment-shell">
	<div class="waline-comment-header">
		<div class="waline-comment-title">
			<span
				class="waline-comment-title-icon flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-[var(--enter-btn-bg)]"
				aria-hidden="true"
			>
				<Icon
					name="material-symbols:forum-outline-rounded"
					class="text-[1.65rem] text-[var(--primary)]"
				/>
			</span>
			<span>{i18n(I18nKey.comments)}</span>
		</div>
		<div class="waline-comment-stats">
			<div class="waline-comment-stat">
				<span
					class="waline-comment-stat-icon flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-[var(--enter-btn-bg)]"
					aria-hidden="true"
				>
					<Icon
						name="material-symbols:visibility-outline-rounded"
						class="text-[1rem] text-[var(--primary)]"
					/>
				</span>
				<span>{i18n(I18nKey.pageViewsLabel)}</span>
				<span class="waline-pageview-count" data-path={path}>--</span>
			</div>
			<div class="waline-comment-stat">
				<span
					class="waline-comment-stat-icon flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-[var(--enter-btn-bg)]"
					aria-hidden="true"
				>
					<Icon
						name="material-symbols:chat-bubble-outline-rounded"
						class="text-[1rem] text-[var(--primary)]"
					/>
				</span>
				<span>{i18n(I18nKey.comments)}</span>
				<span class="waline-comment-count" data-path={path}>--</span>
			</div>
		</div>
	</div>
	<div id="waline-container" class="waline-container">
		<div id="waline"></div>
	</div>
</div>

<style>
	.waline-comment-shell {
		display: grid;
		gap: 1.15rem;
	}

	.waline-comment-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.875rem;
		flex-wrap: wrap;
	}

	.waline-comment-title {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.1rem;
		font-weight: 700;
		color: rgb(23 23 23 / 0.88);
		letter-spacing: 0.01em;
	}

	.waline-comment-title-icon {
		box-shadow:
			0 8px 18px rgb(191 157 116 / 0.1),
			inset 0 1px 0 rgb(255 255 255 / 0.75);
	}

	:global(.dark) .waline-comment-title {
		color: rgb(255 255 255 / 0.92);
	}

	:global(.dark) .waline-comment-title-icon {
		background:
			linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0.04));
		box-shadow:
			0 12px 24px rgb(0 0 0 / 0.18),
			inset 0 1px 0 rgb(255 255 255 / 0.06);
	}

	.waline-comment-stats {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.waline-comment-stat {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.42rem 0.82rem;
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 600;
		color: rgb(23 23 23 / 0.66);
		background:
			linear-gradient(180deg, rgb(255 255 255 / 0.9), rgb(250 247 244 / 0.96));
		border: 1px solid rgb(218 206 192 / 0.72);
		box-shadow:
			0 10px 24px rgb(191 157 116 / 0.08),
			inset 0 1px 0 rgb(255 255 255 / 0.95);
		line-height: 1;
	}

	.waline-comment-stat-icon {
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.78),
			0 5px 12px rgb(191 157 116 / 0.08);
	}

	:global(.dark) .waline-comment-stat {
		color: rgb(255 255 255 / 0.84);
		background:
			linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0.04));
		border-color: rgb(255 255 255 / 0.1);
		box-shadow:
			0 12px 26px rgb(0 0 0 / 0.18),
			inset 0 1px 0 rgb(255 255 255 / 0.06);
	}

	:global(.dark) .waline-comment-stat-icon {
		background: rgb(255 255 255 / 0.08);
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.08),
			0 6px 14px rgb(0 0 0 / 0.14);
	}

	.waline-container {
		min-height: 18rem;
	}
	.waline-container:empty {
		min-height: 0;
	}

	@media (max-width: 640px) {
		.waline-comment-header {
			align-items: flex-start;
		}

		.waline-comment-stats {
			width: 100%;
			gap: 0.55rem;
		}

		.waline-comment-stat {
			padding: 0.4rem 0.72rem;
			font-size: 0.84rem;
		}

		.waline-comment-title-icon {
			height: 2.4rem;
			width: 2.4rem;
		}

		.waline-comment-stat-icon {
			height: 1.7rem;
			width: 1.7rem;
		}
	}
</style>
