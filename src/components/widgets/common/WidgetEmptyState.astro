---
import { Icon } from "astro-icon/components";

interface Props {
	icon: string;
	title: string;
	description?: string;
	compact?: boolean;
}

const { icon, title, description, compact = false } = Astro.props;
const hasDescription = Boolean(description?.trim());
---

<div
	class:list={[
		"widget-empty-state flex flex-col items-center justify-center rounded-[1.5rem] border border-dashed border-black/6 bg-[linear-gradient(180deg,rgba(255,255,255,0.74),rgba(255,255,255,0.5))] text-center dark:border-white/10 dark:bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.02))]",
		compact
			? hasDescription
				? "px-5 py-6"
				: "px-5 py-5"
			: hasDescription
				? "px-6 py-8"
				: "px-6 py-6",
	]}
>
	<div
		class:list={[
			"flex items-center justify-center rounded-[1.25rem] bg-[linear-gradient(135deg,oklch(0.97_0.03_var(--hue)),oklch(0.93_0.06_var(--hue)))] text-[var(--primary)] shadow-[0_12px_30px_rgba(217,153,0,0.16)]",
			hasDescription ? "mb-3" : "mb-2.5",
			compact ? "h-12 w-12" : "h-14 w-14",
		]}
	>
		<Icon
			name={icon}
			class:list={[compact ? "text-2xl" : "text-[1.75rem]"]}
		/>
	</div>
	<p class="text-sm font-semibold leading-6 text-neutral-900 dark:text-neutral-100">
		{title}
	</p>
	{
		description && (
			<p class="mt-2 max-w-[18rem] text-xs leading-6 text-neutral-500 dark:text-neutral-400">
				{description}
			</p>
		)
	}
</div>
