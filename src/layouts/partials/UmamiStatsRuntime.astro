---
import { umamiConfig } from "@/config";
---

{
	umamiConfig.enable && (
		<script is:inline define:vars={{ shareUrl: umamiConfig.shareUrl }}>
			(() => {
				const RUNTIME_KEY = "__mizukiUmamiRuntimeReady";
				if (window[RUNTIME_KEY]) {
					return;
				}
				window[RUNTIME_KEY] = true;

				const runtimeShareUrl = shareUrl;
				if (!runtimeShareUrl) {
					return;
				}

				const REQUEST_TIMEOUT = 10000;
				const shareState = {
					data: null,
					promise: null,
				};

				const parseShareUrl = (rawUrl) => {
					const parsed = new URL(rawUrl);
					const segments = parsed.pathname
						.split("/")
						.filter(Boolean);
					const shareIndex = segments.indexOf("share");

					if (
						shareIndex === -1 ||
						shareIndex >= segments.length - 1
					) {
						throw new Error("无效的 Umami 分享链接");
					}

					const shareId = segments[shareIndex + 1];
					const prefix = segments.slice(0, shareIndex).join("/");
					return {
						apiBase: `${parsed.origin}/${prefix}/api`,
						shareId,
					};
				};

				const { apiBase, shareId } = parseShareUrl(runtimeShareUrl);
				const clearCache = () => {
					shareState.data = null;
					shareState.promise = null;
				};

				const fetchWithTimeout = async (url, options = {}) => {
					const controller = new AbortController();
					const timer = setTimeout(
						() => controller.abort(),
						REQUEST_TIMEOUT,
					);

					try {
						return await fetch(url, {
							cache: "no-store",
							...options,
							signal: controller.signal,
						});
					} finally {
						clearTimeout(timer);
					}
				};

				const getShareData = async () => {
					if (shareState.data) {
						return shareState.data;
					}
					if (shareState.promise) {
						return shareState.promise;
					}

					shareState.promise = (async () => {
						const response = await fetchWithTimeout(
							`${apiBase}/share/${shareId}`,
							{
								headers: {
									accept: "application/json",
								},
							},
						);

						if (!response.ok) {
							shareState.promise = null;
							throw new Error(
								`获取 Umami 分享信息失败: ${response.status}`,
							);
						}

						const data = await response.json();
						shareState.data = data;
						return data;
					})();

					return shareState.promise;
				};

				const normalizeStats = (stats) => ({
					pageviews:
						stats?.pageviews?.value ?? stats?.pageviews ?? 0,
					visitors: stats?.visitors?.value ?? stats?.visitors ?? 0,
					visits: stats?.visits?.value ?? stats?.visits ?? 0,
				});

				const getStats = async (path) => {
					const shareData = await getShareData();
					const params = new URLSearchParams({
						startAt: "0",
						endAt: Date.now().toString(),
					});

					if (path) {
						params.set("path", `eq.${path}`);
					}

					const response = await fetchWithTimeout(
						`${apiBase}/websites/${shareData.websiteId}/stats?${params.toString()}`,
						{
							headers: {
								accept: "application/json",
								"x-umami-share-token": shareData.token,
								"x-umami-share-context": "1",
							},
						},
					);

					if (!response.ok) {
						throw new Error(`获取统计失败: ${response.status}`);
					}

					return normalizeStats(await response.json());
				};

				window.oddmisc = {
					...(window.oddmisc || {}),
					getStats,
					getSiteStats: () => getStats(),
					getPageStats: (path) => getStats(path),
					clearCache,
					umami: {
						clearCache,
					},
				};

				window.dispatchEvent(
					new CustomEvent("mizuki:umami-ready"),
				);
			})();
		</script>
	)
}
