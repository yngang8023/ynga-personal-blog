---
import { commentConfig } from "@/config";
---

{
	commentConfig.enable &&
		commentConfig.system === "waline" &&
		commentConfig.waline?.serverURL && (
			<>
				<script
					is:inline
					define:vars={{
						walineRuntimeConfig: commentConfig.waline,
					}}
				>
					window.__mizukiWalineConfig = walineRuntimeConfig;
				</script>

				<script>
					import { init } from "@waline/client";
					import katex from "katex";
					import "katex/contrib/mhchem";
					import "katex/dist/katex.min.css";
					import {
						isTrustedKatexCommand,
						katexMacros,
						katexStrict,
					} from "../../utils/katex-options.mjs";
					import {
						createWalineDeleteConfirmBridge,
						matchWalineDeleteButton,
						refreshWalineStats,
						teardownWalineInstance,
					} from "./waline-runtime-utils.js";

					const CONTAINER_ID = "waline";
					const WRAPPER_ID = "waline-container";
					const ROOT_MARGIN = "240px";
					const PREVIEW_RETRY_DELAY = 120;
					const PREVIEW_RETRY_LIMIT = 10;
					const getRuntimeConfig = () =>
						window.__mizukiWalineConfig || null;

					const getCurrentPath = () => window.location.pathname;

					const getCommentShell = () =>
						document.querySelector(".waline-comment-shell");

					const getCommentEditors = () =>
						Array.from(
							document.querySelectorAll<HTMLElement>(
								`#${CONTAINER_ID} .wl-comment`,
							),
						);

					const getPreviewButton = (
						commentEditor: ParentNode,
					): HTMLButtonElement | null =>
						commentEditor.querySelector<HTMLButtonElement>(
							".wl-actions button.wl-action:last-of-type",
						);

					const getPreviewPanel = (
						commentEditor: ParentNode,
					): HTMLElement | null =>
						commentEditor.querySelector<HTMLElement>(".wl-preview");

					const getEditorTextarea = (
						commentEditor: ParentNode,
					): HTMLTextAreaElement | null =>
						commentEditor.querySelector<HTMLTextAreaElement>(
							".wl-editor",
						);

					const isPreviewVisible = (previewPanel: HTMLElement) =>
						getComputedStyle(previewPanel).display !== "none";

					const togglePreviewForEditor = (
						commentEditor: HTMLElement,
					) => {
						const previewButton = getPreviewButton(commentEditor);
						const previewPanel = getPreviewPanel(commentEditor);
						const textarea = getEditorTextarea(commentEditor);

						if (!previewButton || !previewPanel || !textarea) {
							return false;
						}

						const hasContent = textarea.value.trim().length > 0;
						const isActive =
							previewButton.classList.contains("active") &&
							isPreviewVisible(previewPanel);

						if (hasContent !== isActive) {
							previewButton.click();
						}

						const nextState =
							previewButton.classList.contains("active") &&
							isPreviewVisible(previewPanel);

						return hasContent ? nextState : !nextState;
					};

					const syncPreviewVisibility = (attempt = 0) => {
						const commentEditors = getCommentEditors();

						if (!commentEditors.length) {
							if (attempt < PREVIEW_RETRY_LIMIT) {
								window.setTimeout(
									() =>
										syncPreviewVisibility(attempt + 1),
									PREVIEW_RETRY_DELAY,
								);
							}
							return;
						}

						const allReady = commentEditors.every(
							togglePreviewForEditor,
						);

						if (!allReady && attempt < PREVIEW_RETRY_LIMIT) {
							window.setTimeout(
								() =>
									syncPreviewVisibility(attempt + 1),
								PREVIEW_RETRY_DELAY,
							);
						}
					};

					const getOptions = () => {
						const config = getRuntimeConfig();
						if (!config) {
							return null;
						}

						const normalizedConfig = { ...config };
						const shell = getCommentShell();
						const placeholder =
							shell?.getAttribute("data-waline-placeholder") ||
							undefined;
						const sofa =
							shell?.getAttribute("data-waline-sofa") ||
							undefined;
						const reactionTitle =
							shell?.getAttribute("data-waline-reaction-title") ||
							undefined;
						const reactionEnabled =
							shell?.getAttribute("data-waline-reaction");

						// Waline 的 Vue 组件会对 imageUploader 做 Function 类型校验。
						// 当配置为 false 时虽然语义上表示禁用，但会触发开发警告，
						// 这里在运行时移除该字段，实际隐藏交由样式控制。
						if (normalizedConfig.imageUploader === false) {
							delete normalizedConfig.imageUploader;
						}

						if (!normalizedConfig.turnstileKey) {
							delete normalizedConfig.turnstileKey;
						}

						if (!normalizedConfig.recaptchaV3Key) {
							delete normalizedConfig.recaptchaV3Key;
						}

						if (placeholder) {
							normalizedConfig.locale = {
								...(normalizedConfig.locale || {}),
								placeholder,
							};
						}

						if (sofa) {
							normalizedConfig.locale = {
								...(normalizedConfig.locale || {}),
								sofa,
							};
						}

						if (reactionTitle) {
							normalizedConfig.locale = {
								...(normalizedConfig.locale || {}),
								reactionTitle,
							};
						}

						if (reactionEnabled === "false") {
							normalizedConfig.reaction = false;
						}

						return {
							...normalizedConfig,
							texRenderer: (
								blockMode: boolean,
								tex: string,
							) =>
								katex.renderToString(tex, {
									displayMode: blockMode,
									throwOnError: false,
									strict: katexStrict,
									trust: (context: { command: string }) =>
										isTrustedKatexCommand(context),
									macros: katexMacros,
								}),
							el: `#${CONTAINER_ID}`,
							path: getCurrentPath(),
						};
					};

					const runtime: NonNullable<
						Window["__mizukiWalineRuntime"]
					> = window.__mizukiWalineRuntime || {
						instance: null,
						mountedContainer: null,
						observer: null,
						previewObserver: null,
						statsObserver: null,
						initialized: false,
						loading: false,
						initAttemptedPath: "",
						previewTimer: null,
						statsRefreshTimer: null,
						statsAborters: null,
						originalConfirm: window.confirm.bind(window),
						confirmProxy: (message = "") =>
							runtime.deleteConfirmBridge?.confirm(message) ??
							runtime.originalConfirm(message),
						deleteConfirmBridge: null,
						deleteClickCaptureHandler: null,
						bound: false,
						schedulePreviewEnable: () => {
							if (runtime.previewTimer !== null) {
								window.clearTimeout(runtime.previewTimer);
							}

							runtime.previewTimer = window.setTimeout(() => {
								runtime.previewTimer = null;
								syncPreviewVisibility();
							}, 40);
						},
						refreshStats: () => {
							const config = getRuntimeConfig();

							if (!config?.serverURL || !getCommentShell()) {
								return;
							}

							runtime.statsAborters?.abortCommentCount?.();
							runtime.statsAborters?.abortPageviewCount?.();
							runtime.statsAborters = refreshWalineStats({
								serverURL: config.serverURL,
								path: getCurrentPath(),
								lang: config.lang,
							});
						},
						scheduleStatsRefresh: () => {
							if (runtime.statsRefreshTimer !== null) {
								window.clearTimeout(
									runtime.statsRefreshTimer,
								);
							}

							runtime.statsRefreshTimer = window.setTimeout(
								() => {
									runtime.statsRefreshTimer = null;
									runtime.refreshStats();
								},
								180,
							);
						},
						observeCommentStats: () => {
							const container =
								document.getElementById(CONTAINER_ID);
							const cards =
								container?.querySelector<HTMLElement>(
									".wl-cards",
								) || null;

							runtime.statsObserver?.disconnect();
							runtime.statsObserver = null;

							if (!cards) {
								return;
							}

							runtime.statsObserver = new MutationObserver(
								(mutations) => {
									const hasCommentTreeChange =
										mutations.some(
											(mutation) =>
												mutation.type ===
													"childList" &&
												(mutation.addedNodes.length >
													0 ||
													mutation.removedNodes
														.length > 0),
										);

									if (hasCommentTreeChange) {
										runtime.scheduleStatsRefresh();
									}
								},
							);

							runtime.statsObserver.observe(cards, {
								childList: true,
								subtree: true,
							});
						},
						observePreviewDefaults: () => {
							const container =
								document.getElementById(CONTAINER_ID);

							runtime.previewObserver?.disconnect();
							runtime.previewObserver = null;

							if (!container) {
								return;
							}

							runtime.previewObserver = new MutationObserver(
								() => {
									runtime.schedulePreviewEnable();
									runtime.observeCommentStats();
								},
							);
							runtime.previewObserver.observe(container, {
								childList: true,
								subtree: true,
							});

							runtime.observeCommentStats();
							runtime.schedulePreviewEnable();
						},
						installDeleteConfirmBridge: () => {
							const container =
								document.getElementById(CONTAINER_ID);

							if (!container) {
								return;
							}

							runtime.teardownDeleteConfirmBridge();
							runtime.deleteConfirmBridge =
								createWalineDeleteConfirmBridge({
									resolveConfirm: () =>
										window.__mizukiConfirm?.confirm ||
										null,
									nativeConfirm: runtime.originalConfirm,
									matchDeleteButton: (target) =>
										matchWalineDeleteButton(
											target,
											CONTAINER_ID,
										),
								});
							runtime.deleteClickCaptureHandler = (
								event: Event,
							) => {
								runtime.deleteConfirmBridge?.handleDeleteClick(
									event,
								);
							};

							container.addEventListener(
								"click",
								runtime.deleteClickCaptureHandler,
								true,
							);

							if (window.confirm !== runtime.confirmProxy) {
								window.confirm = runtime.confirmProxy;
							}
						},
						teardownDeleteConfirmBridge: () => {
							const container =
								document.getElementById(CONTAINER_ID) ||
								runtime.mountedContainer;

							if (
								container &&
								runtime.deleteClickCaptureHandler
							) {
								container.removeEventListener(
									"click",
									runtime.deleteClickCaptureHandler,
									true,
								);
							}

							runtime.deleteClickCaptureHandler = null;
							runtime.deleteConfirmBridge?.reset();
							runtime.deleteConfirmBridge = null;

							if (window.confirm === runtime.confirmProxy) {
								window.confirm = runtime.originalConfirm;
							}
						},
						mount: async () => {
							const container =
								document.getElementById(CONTAINER_ID);
							const options = getOptions();

							if (!container || !options || runtime.loading) {
								return;
							}

							runtime.loading = true;

							try {
								runtime.teardownDeleteConfirmBridge();
								runtime.previewObserver?.disconnect();
								runtime.previewObserver = null;
								runtime.statsObserver?.disconnect();
								runtime.statsObserver = null;

								if (runtime.previewTimer !== null) {
									window.clearTimeout(runtime.previewTimer);
									runtime.previewTimer = null;
								}

								if (runtime.statsRefreshTimer !== null) {
									window.clearTimeout(
										runtime.statsRefreshTimer,
									);
									runtime.statsRefreshTimer = null;
								}

								runtime.statsAborters?.abortCommentCount?.();
								runtime.statsAborters?.abortPageviewCount?.();
								runtime.statsAborters = null;

								if (runtime.instance) {
									const teardownResult =
										teardownWalineInstance(
											runtime.instance,
											runtime.mountedContainer,
										);

									if (
										teardownResult.reason ===
										"destroy-failed"
									) {
										console.warn(
											"[Waline] 销毁旧实例失败，改为直接重置引用:",
											teardownResult.error,
										);
									}
								}

								runtime.instance = null;
								runtime.mountedContainer = null;
								container.innerHTML = "";
								runtime.instance = init(options);
								runtime.mountedContainer = container;
								runtime.initialized = true;
								runtime.initAttemptedPath = getCurrentPath();
								runtime.observePreviewDefaults();
								runtime.installDeleteConfirmBridge();
								runtime.scheduleStatsRefresh();
							} catch (error) {
								console.error("[Waline] 初始化失败:", error);
							} finally {
								runtime.loading = false;
							}
						},
						destroy: () => {
							runtime.observer?.disconnect();
							runtime.observer = null;
							runtime.previewObserver?.disconnect();
							runtime.previewObserver = null;
							runtime.statsObserver?.disconnect();
							runtime.statsObserver = null;
							if (runtime.previewTimer !== null) {
								window.clearTimeout(runtime.previewTimer);
								runtime.previewTimer = null;
							}
							if (runtime.statsRefreshTimer !== null) {
								window.clearTimeout(
									runtime.statsRefreshTimer,
								);
								runtime.statsRefreshTimer = null;
							}
							runtime.statsAborters?.abortCommentCount?.();
							runtime.statsAborters?.abortPageviewCount?.();
							runtime.statsAborters = null;
							runtime.teardownDeleteConfirmBridge();
							if (runtime.instance) {
								const teardownResult =
									teardownWalineInstance(
										runtime.instance,
										runtime.mountedContainer,
									);

								if (
									teardownResult.reason ===
									"destroy-failed"
								) {
									console.warn(
										"[Waline] 销毁实例失败，已跳过:",
										teardownResult.error,
									);
								}
							}
							runtime.instance = null;
							runtime.mountedContainer = null;
							runtime.initialized = false;
						},
						setupLazyLoad: () => {
							const wrapper =
								document.getElementById(WRAPPER_ID);
							if (!wrapper) {
								runtime.destroy();
								return;
							}

							runtime.observer?.disconnect();
							runtime.observer = new IntersectionObserver(
								(entries) => {
									if (entries[0]?.isIntersecting) {
										runtime.observer?.disconnect();
										runtime.observer = null;
										runtime.mount();
									}
								},
								{ rootMargin: ROOT_MARGIN },
							);

							runtime.observer.observe(wrapper);
						},
						refresh: () => {
							const wrapper =
								document.getElementById(WRAPPER_ID);
							if (!wrapper) {
								runtime.destroy();
								return;
							}

							if (
								runtime.initialized &&
								runtime.initAttemptedPath === getCurrentPath()
							) {
								runtime.scheduleStatsRefresh();
								return;
							}

							runtime.setupLazyLoad();
						},
					};

					window.__mizukiWalineRuntime = runtime;

					const scheduleRefresh = () => {
						window.setTimeout(() => {
							runtime.scheduleStatsRefresh();
							runtime.refresh();
						}, 160);
					};

					if (!runtime.bound) {
						document.addEventListener(
							"mizuki:page:loaded",
							scheduleRefresh,
						);
						document.addEventListener(
							"astro:page-load",
							scheduleRefresh,
						);
						runtime.bound = true;
					}

					if (document.readyState === "loading") {
						document.addEventListener(
							"DOMContentLoaded",
							scheduleRefresh,
							{ once: true },
						);
					} else {
						scheduleRefresh();
					}
				</script>
			</>
		)
}
